<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <ResourceId>/subscriptions/4769f880-60b4-4e1c-8557-c613fbddba0e/resourceGroups/appsvc_windows_centralus2/providers/Microsoft.Web/sites/HITDEVTEAMPROJ</ResourceId>
    <ResourceGroup>appsvc_windows_centralus2</ResourceGroup>
    <PublishProvider>AzureWebSite</PublishProvider>
    <SiteUrlToLaunchAfterPublish>http://hitdevteamproj.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>True</LaunchSiteAfterPublish>
    <MSDeployServiceURL>hit503spring2021.scm.azurewebsites.net:443</MSDeployServiceURL>
    <DeployIisAppPath>HITDEVTEAMPROJ</DeployIisAppPath>
    <SkipExtraFilesOnServer>True</SkipExtraFilesOnServer>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployBackup>True</EnableMSDeployBackup>
    <UserName>$HITDEVTEAMPROJ</UserName>
    <_SavePWD>True</_SavePWD>
  </PropertyGroup>
</Project>