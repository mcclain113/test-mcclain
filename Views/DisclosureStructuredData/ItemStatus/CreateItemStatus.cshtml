@model IS_Proj_HIT.ViewModels.DisclosureStructuredData.DisclosureStructuredDataViewModel
@{
    ViewBag.Title = "Create Item Status";
}

<h1>Create</h1>

<h4>Item Status</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
               <div class="form-group col-sm-2">
                    <label asp-for="ItemStatus.ItemStatusId" class="control-label">Status Id</label>
                    <input asp-for="ItemStatus.ItemStatusId" 
                        class="form-control" maxlength="2" required
                        placeholder="Example:  CP" />
                    <span asp-validation-for="ItemStatus.ItemStatusId" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-4">
                    <label asp-for="ItemStatus.ItemStatus1" class="control-label">Name of Status</label>
                    <input asp-for="ItemStatus.ItemStatus1" 
                        class="form-control" maxlength="20" required
                        placeholder="Example:  Completed" />
                    <span asp-validation-for="ItemStatus.ItemStatus1" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="ItemStatus.ItemStatusDescription" class="control-label">Description of Status</label>
                    <input asp-for="ItemStatus.ItemStatusDescription" 
                        class="form-control" maxlength="100"  
                        placeholder="Example:  The request is completed"/>
                    <span asp-validation-for="ItemStatus.ItemStatusDescription" class="text-danger"></span>
                </div>
                                                
                @if (ViewBag.ErrorMessage != null) {
                    <div class="form-group col-12">
                        <span class="text-danger">@ViewBag.ErrorMessage</span>
                    </div>
                }


                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>

            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="DisclosureStructuredData" asp-action="ViewItemStatuses">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}