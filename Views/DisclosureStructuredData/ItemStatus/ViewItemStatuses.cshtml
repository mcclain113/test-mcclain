@model List<IS_Proj_HIT.Entities.ItemStatus>

@{
    ViewData["Title"] = "Item Statuses";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Item Statuses
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="CreateItemStatus">Create New</a>
</p>

<table class="stripe nowrap" id="itemStatusTable">
    <thead>
        <tr>
            <th>
                Id
            </th>
            <th>
                Item Status
            </th>
            <th>
                Status Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var itemStatus in Model)
        {
            <tr>
                <td>
                    @itemStatus.ItemStatusId
                </td>
                <td>
                    @itemStatus.ItemStatus1
                </td>
                <td>
                    @itemStatus.ItemStatusDescription
                </td>
                <td>
                   
                    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="EditItemStatus" asp-route-id="@itemStatus.ItemStatusId">Edit</a>
                    <a class="btn btn-danger" asp-controller="DisclosureStructuredData" asp-action="DeleteItemStatus" asp-route-id="@itemStatus.ItemStatusId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
        <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#itemStatusTable').DataTable({
                columns: [null, null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No request purposes found'
                }
            });
        });
    </script>
}