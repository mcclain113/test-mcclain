@model List<IS_Proj_HIT.Entities.RequesterType>

@{
    ViewData["Title"] = "Disclosure Requester Types";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Disclosure Requester Types
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="CreateRequesterType">Create New</a>
</p>

<table class="stripe nowrap" id="requesterTypeTable">
    <thead>
        <tr>
            <th>
                Requester Type Name
            </th>
            <th>
                Requester Type Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var requesterType in Model)
        {
            <tr>
                <td>
                    @requesterType.RequesterType1
                </td>
                <td>
                    @requesterType.RequesterTypeDescription
                </td>
                <td>
                   
                    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="EditRequesterType" asp-route-id="@requesterType.RequesterTypeId">Edit</a>
                    <a class="btn btn-danger" asp-controller="DisclosureStructuredData" asp-action="DeleteRequesterType" asp-route-id="@requesterType.RequesterTypeId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#requesterTypeTable').DataTable({
                columns: [null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No request purposes found'
                }
            });
        });
    </script>
}