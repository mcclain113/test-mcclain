@model IS_Proj_HIT.ViewModels.DisclosureStructuredData.DisclosureStructuredDataViewModel
@{
    ViewBag.Title = "Delete Requester Type";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>RequesterType</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                
                <input type="hidden" asp-for="RequesterType.RequesterTypeId" value="@Model.RequesterType.RequesterTypeId" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="RequesterType.RequesterType1" class="control-label">Requester Type Name</label>
                    <input asp-for="RequesterType.RequesterType1" class="form-control" maxlength="50" required />
                    
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="RequesterType.RequesterTypeDescription" class="control-label">Requester Type Description</label>
                    <input asp-for="RequesterType.RequesterTypeDescription" class="form-control" maxlength="100" required />
                    
                </div>

                <div class="form-group">
                    <a asp-controller="DisclosureStructuredData" asp-action="ViewRequesterTypes" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>