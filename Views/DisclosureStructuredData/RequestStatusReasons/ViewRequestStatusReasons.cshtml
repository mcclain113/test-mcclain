@model List<IS_Proj_HIT.Entities.RequestStatusReason>

@{
    ViewData["Title"] = "Disclosure Request Status Reasons";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Disclosure Request Release Status Reasons
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="CreateRequestStatusReason">Create New</a>
</p>

<table class="stripe nowrap" id="requestStatusReasonTable">
    <thead>
        <tr>
            <th>
                Request Status Reason
            </th>
            <th>
                Reason Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var requestStatusReason in Model)
        {
            <tr>
                <td>
                    @requestStatusReason.RequestStatusReason1
                </td>
                <td>
                    @requestStatusReason.StatusReasonDescription
                </td>
                <td>
                   
                    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="EditRequestStatusReason" asp-route-id="@requestStatusReason.RequestStatusReasonId">Edit</a>
                    <a class="btn btn-danger" asp-controller="DisclosureStructuredData" asp-action="DeleteRequestStatusReason" asp-route-id="@requestStatusReason.RequestStatusReasonId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#requestStatusReasonTable').DataTable({
                columns: [null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No request purposes found'
                }
            });
        });
    </script>
}