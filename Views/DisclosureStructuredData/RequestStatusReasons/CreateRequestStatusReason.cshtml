@model IS_Proj_HIT.ViewModels.DisclosureStructuredData.DisclosureStructuredDataViewModel
@{
    ViewBag.Title = "Create Request Status Reason";
}

<h1>Create</h1>

<h4>Request Status Reason</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group col-sm-4">
                    <label asp-for="RequestStatusReason.RequestStatusReason1" class="control-label">Name of Reason</label>
                    <input asp-for="RequestStatusReason.RequestStatusReason1" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Restricted Record" />
                    <span asp-validation-for="RequestStatusReason.RequestStatusReason1" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-8">
                    <label asp-for="RequestStatusReason.StatusReasonDescription" class="control-label">Description of Reason</label>
                    <input asp-for="RequestStatusReason.StatusReasonDescription" 
                        class="form-control" maxlength="100" 
                        placeholder="Example:  The request is for a restricted record"/>
                    <span asp-validation-for="RequestStatusReason.StatusReasonDescription" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>

            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="DisclosureStructuredData" asp-action="ViewRequestStatusReasons">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}