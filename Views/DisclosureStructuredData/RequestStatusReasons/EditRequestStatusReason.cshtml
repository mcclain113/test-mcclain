@model IS_Proj_HIT.ViewModels.DisclosureStructuredData.DisclosureStructuredDataViewModel
@{
    ViewBag.Title = "Edit Request Status Reason";
}

<h1>Edit</h1>

<h4>Request Status Reason</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="RequestStatusReason.RequestStatusReasonId" value="@Model.RequestStatusReason.RequestStatusReasonId" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="RequestStatusReason.RequestStatusReason1" class="control-label">Request Status Reason</label>
                    <input asp-for="RequestStatusReason.RequestStatusReason1" class="form-control" maxlength="50" required />
                    <span asp-validation-for="RequestStatusReason.RequestStatusReason1" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="RequestStatusReason.StatusReasonDescription" class="control-label">Reason Description</label>
                    <input asp-for="RequestStatusReason.StatusReasonDescription" class="form-control" maxlength="100" required />
                    <span asp-validation-for="RequestStatusReason.StatusReasonDescription" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <a asp-controller="DisclosureStructuredData" asp-action="ViewRequestStatusReasons" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Save Changes" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}