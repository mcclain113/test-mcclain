@model List<IS_Proj_HIT.Entities.RequesterStatus>

@{
    ViewData["Title"] = "Disclosure Requester Status";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Disclosure Requester Statuses
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="CreateRequesterStatus">Create New</a>
</p>

<table class="stripe nowrap" id="requesterStatusTable">
    <thead>
        <tr>
            <th>
                Id
            </th>
            <th>
                Requester Status Name
            </th>
            <th>
                Requester Status Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var requesterStatus in Model)
        {
            <tr>
                <td>
                    @requesterStatus.RequesterStatusId
                </td>
                <td>
                    @requesterStatus.RequesterStatus1
                </td>
                <td>
                    @requesterStatus.RequesterStatusDescription
                </td>
                <td>
                   
                    <a class="btn btn-primary" asp-controller="DisclosureStructuredData" asp-action="EditRequesterStatus" asp-route-id="@requesterStatus.RequesterStatusId">Edit</a>
                    <a class="btn btn-danger" asp-controller="DisclosureStructuredData" asp-action="DeleteRequesterStatus" asp-route-id="@requesterStatus.RequesterStatusId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#requesterStatusTable').DataTable({
                columns: [null, null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No request priorities found'
                }
            });
        });
    </script>
}