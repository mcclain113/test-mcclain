@model IS_Proj_HIT.ViewModels.DisclosureStructuredData.DisclosureStructuredDataViewModel
@{
    ViewBag.Title = "Create Requester Status";
}

<h1>Create</h1>

<h4>Requester Status</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group col-sm-2">
                    <label asp-for="RequesterStatus.RequesterStatusId" class="control-label">Requester Status Id</label>
                    <input asp-for="RequesterStatus.RequesterStatusId" 
                        class="form-control" maxlength="2" required
                        placeholder="Example:  AC" />
                    <span asp-validation-for="RequesterStatus.RequesterStatusId" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-4">
                    <label asp-for="RequesterStatus.RequesterStatus1" class="control-label">Requester Status Name</label>
                    <input asp-for="RequesterStatus.RequesterStatus1" 
                        class="form-control" maxlength="20" required
                        placeholder="Example:  Active" />
                    <span asp-validation-for="RequesterStatus.RequesterStatus1" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="RequesterStatus.RequesterStatusDescription" class="control-label">Description of Requester Status</label>
                    <input asp-for="RequesterStatus.RequesterStatusDescription" 
                        class="form-control" maxlength="100" 
                        placeholder="Example:  The Requestor is currently Active and authorized"/>
                    <span asp-validation-for="RequesterStatus.RequesterStatusDescription" class="text-danger"></span>
                </div>
                                
                @if (ViewBag.ErrorMessage != null) {
                    <div class="form-group col-12">
                        <span class="text-danger">@ViewBag.ErrorMessage</span>
                    </div>
                }

                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>

            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="DisclosureStructuredData" asp-action="ViewRequesterStatuses">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}