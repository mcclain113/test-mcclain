@model IS_Proj_HIT.ViewModels.DisclosureStructuredData.DisclosureStructuredDataViewModel
@{
    ViewBag.Title = "Create Document Requested Item";
}

<h1>Create</h1>

<h4>Document Requested Item</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group col-sm-6">
                    <label asp-for="DocumentRequested.DocumentRequested1" class="control-label">Type of Document</label>
                    <input asp-for="DocumentRequested.DocumentRequested1" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Discharge Summary" />
                    <span asp-validation-for="DocumentRequested.DocumentRequested1" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="DocumentRequested.DocumentRequestedDescription" class="control-label">Description of Document</label>
                    <input asp-for="DocumentRequested.DocumentRequestedDescription" 
                        class="form-control" maxlength="100"  
                        placeholder="Example:  The request is for the Discharge Summary"/>
                    <span asp-validation-for="DocumentRequested.DocumentRequestedDescription" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>

            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="DisclosureStructuredData" asp-action="ViewDocumentRequesteds">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}