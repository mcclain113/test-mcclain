@model IS_Proj_HIT.ViewModels.DisclosureStructuredData.DisclosureStructuredDataViewModel
@{
    ViewBag.Title = "Delete Request Release Format";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Request Release Format</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                
                <input type="hidden" asp-for="RequestReleaseFormat.ReleaseFormatId" value="@Model.RequestReleaseFormat.ReleaseFormatId" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="RequestReleaseFormat.RequestReleaseFormat1" class="control-label">Request Purpose</label>
                    <input asp-for="RequestReleaseFormat.RequestReleaseFormat1" class="form-control" maxlength="50" required />
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="RequestReleaseFormat.ReleaseFormatDescription" class="control-label">Purpose Description</label>
                    <input asp-for="RequestReleaseFormat.ReleaseFormatDescription" class="form-control" maxlength="100" required />                    
                </div>

                <div class="form-group">
                    <a asp-controller="DisclosureStructuredData" asp-action="ViewRequestReleaseFormats" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

<div>
    <a asp-controller="DisclosureStructuredData" asp-action="ViewRequestReleaseFormats">Back to List</a>
</div>