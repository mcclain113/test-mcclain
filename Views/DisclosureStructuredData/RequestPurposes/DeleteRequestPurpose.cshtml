@model IS_Proj_HIT.ViewModels.DisclosureStructuredData.DisclosureStructuredDataViewModel
@{
    ViewBag.Title = "Delete Purpose of Disclosure";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Purpose of Disclosure</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                
                <input type="hidden" asp-for="RequestPurpose.PurposeId" value="@Model.RequestPurpose.PurposeId" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="RequestPurpose.RequestPurpose1" class="control-label">Request Purpose</label>
                    <input asp-for="RequestPurpose.RequestPurpose1" class="form-control" maxlength="100" required />
                    
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="RequestPurpose.PurposeDescription" class="control-label">Purpose Description</label>
                    <input asp-for="RequestPurpose.PurposeDescription" class="form-control" maxlength="100" required />
                    
                </div>

                <div class="form-group">
                    <a asp-controller="DisclosureStructuredData" asp-action="ViewRequestPurposes" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

<div>
    <a asp-controller="DisclosureStructuredData" asp-action="ViewRequestPurposes">Back to List</a>
</div>