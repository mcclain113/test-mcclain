@using IS_Proj_HIT.Entities
@model IS_Proj_HIT.ViewModels.Disclosure.RequestDetailsViewModel

@{
    ViewData["Title"] = "DisclosureDetails";
    var userPermissions = ViewData["UserPermissions"] as List<string>;
}

<partial name="RequestBannerPartial" model="Model" />
<partial name="_RequestMenu" model="Model" />

<div class="card" style="border:none">

    <!--Header Content-->
    <div class="card-header requestDetailData">
        <h3>

            Invoice

            @if (userPermissions != null && (userPermissions.Contains("DisclosureRequestEdit")) && Model.Disclosure != null )
            {
                <a class="btn btn-danger float-right m-1"
                   id="removeButton"
                   onclick="return confirm('Are you sure you want to Delete this Invoice?')"
                   asp-route-disclosureId="@Model.Disclosure.DisclosureId"
                   asp-route-requestId="@Model.Request.RequestId"
                   asp-action="DeleteDisclosure">
                    Delete
                </a>
                <a class="btn btn-info float-right m-1" id="editBtn" onclick="toggleEdit()">Edit</a>
                <a class="btn btn-secondary text-white float-right m-1"
                   id="cancelBtn"
                   onclick="toggleEdit(); return confirm('Are you sure you want to Cancel? All changes will be lost.')"
                   asp-action="DisclosureDetails"
                   style="display:none">Cancel</a>
            }
            @if (userPermissions != null && (userPermissions.Contains("DisclosureRequestEdit")) && Model.Disclosure == null)
            {
                <a class="btn btn-info float-right" id="addBtn" onclick="toggleAdd()">Add Invoice</a>
            }
        </h3>
    </div>

    @if(Model.Disclosure != null)
    {   <!--View Mode If Theres a Disclosure-->
        <div class="card-body bg-light" id="viewMode">
            <div class="container">
                <div class="row">
                    @if (Model.Disclosure.DisclosureDate != null)
                    {
                        <div class="col-4 ">
                            Disclosure Date: <b>@Model.Disclosure.DisclosureDate.Value.ToShortDateString()</b>
                        </div>
                    }
                    else
                    {
                        <div class="col-4 ">
                            Disclosure Date: <b></b>
                        </div>
                    }
                    @if (Model.Disclosure.InvoiceDate != null)
                    {
                        <div class="col-4">
                            Invoice Date: <b>@Model.Disclosure.InvoiceDate.Value.ToShortDateString()</b>
                        </div>
                    }
                    else
                    {
                        <div class="col-4">
                            Invoice Date: <b></b>
                        </div>
                    }
                    @if (Model.Disclosure.InvoiceNumber != null)
                    {
                        <div class="col-4">
                            Invoice Number: <b>@Model.Disclosure.InvoiceNumber</b>
                        </div>
                    }
                    else
                    {
                        <div class="col-4">
                            Invoice Number: <b></b>
                        </div>
                    }
                </div>
                <hr />
                <div class="row">
                    @if (Model.Disclosure.IsPaymentRequired != null)
                    {
                        <div class="col-4">
                            Pre-Payment Required: <b></b>
                        </div>
                    }
                    else if (Model.Disclosure.IsPaymentRequired == true)
                    {
                        <div class="col-4">
                            Pre-Payment Required: <b>Yes</b>
                        </div>
                    }
                    else
                    {
                        <div class="col-4">
                            Pre-Payment Required: <b>No</b>
                        </div>
                    }
                    @if (Model.Disclosure.Comments != null)
                    {
                        <div class="col-4">
                            Comments: <b>@Model.Disclosure.Comments</b>
                        </div>
                    }
                    else
                    {
                        <div class="col-4">
                            Comments:
                        </div>
                    }
                    @if(Model.Disclosure.InvoiceTotal != null)
                    {
                        <div class="col-4">
                            Balance due:  <b>$@ViewBag.InvoiceBalance</b>
                        </div>
                    }
                    else
                    {
                        <div class="col-4">
                        Balance due:  
                    </div>
                    }
                    
                </div>
                <hr class="double-line"/>
            </div>
        </div>
                                       
        <!--Edit Mode-->
        <form id="editMode" style="display:none;" asp-action="EditDisclosure">
            @Html.AntiForgeryToken()
            <input type="hidden" value="@Model.DisclosureBeingEdited.DisclosureId" asp-for="DisclosureBeingEdited.DisclosureId" />
            <input type="hidden" value="@Model.Request.RequestId" asp-for="Request.RequestId" />
            <div class="card-body bg-light">
                <div class="container">
                    <div class="row">
                        <div class="col-4 d-flex">
                            <div><label class="mt-1">Disclosure Date: </label></div>
                            <div class="mx-2">
                                <input asp-for="@Model.DisclosureBeingEdited.DisclosureDate"
                                        type="date"
                                        placeholder="@Model.DisclosureBeingEdited.DisclosureDate"
                                        class="form-control"/>
                            </div>
                        </div>
                        <div class="col-4 d-flex">
                            <div><label class="mt-1">Invoice Date: </label></div>
                            <div class="mx-2">
                                <input asp-for="@Model.DisclosureBeingEdited.InvoiceDate"
                                        type="date"
                                        placeholder="@Model.DisclosureBeingEdited.InvoiceDate"
                                        class="form-control" />
                            </div>
                        </div>
                        @if (Model.Disclosure.InvoiceNumber != null)
                        {
                            <div class="col-4">
                                Invoice Number: <b>@Model.Disclosure.InvoiceNumber</b>
                            </div>
                        }
                        else
                        {
                            <div class="col-4">
                                Invoice Number: <b></b>
                            </div>
                        }
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-4 d-flex">
                            <div>
                                <label class="mt-1">Pre-Payment Required: </label>
                            </div>
                            <div class="mx-2">
                                <select asp-for="@Model.DisclosureBeingEdited.IsPaymentRequired" class="form-control">
                                    <option>Select</option>
                                    <option value="1">Yes</option>
                                    <option value="0">No</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-4 d-flex">
                            <div><label class="mt-1">Comments: </label></div>
                            <div class="mx-2">
                                <input asp-for="@Model.DisclosureBeingEdited.Comments"
                                        type="text"
                                        placeholder="@Model.DisclosureBeingEdited.Comments"
                                        class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <button class="btn btn-primary btn-block" id="saveBtn" type="submit" style="display:none">Update Invoice</button>
        </form>
  
        <!--Fee Table-->
        <div class="card-body bg-light">
            <div class="container">
                <h5 class="col-12 bg-primary py-3 text-light font-weight-bold d-flex justify-content-between align-items-center">
                    Fees
                    @if (userPermissions != null && (userPermissions.Contains("DisclosureRequestEdit")) )
                    {
                        <button type="button" class="btn btn-outline-success" id="addDisclosureFeeBtn" onclick="toggleAddFee()">

                            <i class="fas fa-plus"></i> Add Fee
                        </button>
                    }
                </h5>
                <table class="table table-striped table-bordered" id="feeTable">
                    <thead class="bg-primary text-white">
                        <tr>
                            <th class="fee-column">Amount</th>
                            <th class="description-column">Description</th>
                            <th class="comments-column">Units</th>
                            <th class="item-count-column">Count</th>
                            <th class="total-fee-column">Total</th>
                            <th class="action-column">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            decimal subtotal = 0.00M;
                        }
                        @for (int i = 0; i < Model.DisclosureFeeDetails.Count; i++)
                        {
                            var feeDetail = Model.DisclosureFeeDetails[i];
                            @if (feeDetail.DisclosureFeeTypeId != ViewBag.EditDisclosureFeeTypeId)
                            {
                                <tr>
                                    <td>$@feeDetail.PerItemFee</td>
                                    <td>@feeDetail.FeeDescription</td>
                                    <td>@feeDetail.Comments</td>
                                    <td>@feeDetail.ItemCount</td>
                                    <td>$@(feeDetail.PerItemFee * feeDetail.ItemCount)</td>
                                    @if (userPermissions != null && (userPermissions.Contains("DisclosureRequestEdit")) )
                                    {
                                        <td>
                                            <a asp-action="EditDisclosureFeeDetail"
                                            asp-route-disclosureFeeTypeId="@feeDetail.DisclosureFeeTypeId"
                                            asp-route-requestId="@Model.Request.RequestId"
                                            class="btn btn-info text-white"
                                            style="margin-right: 4px; border:none;">
                                                Edit
                                            </a>
                                            <a onclick="return confirm('Are you sure you want to delete this item?')"
                                            asp-action="DeleteDisclosureFeeDetail"
                                            asp-route-disclosureId ="@Model.Disclosure.DisclosureId"
                                            asp-route-disclosureFeeTypeId="@feeDetail.DisclosureFeeTypeId"
                                            asp-route-requestId="@Model.Request.RequestId"
                                            class="btn btn-danger text-white"
                                            style="border:none;">
                                                Delete
                                            </a>
                                        </td>
                                    }
                                    else
                                    {
                                        <td></td>
                                    }
                                </tr>
                            }
                            else
                            {
                                <form id="editFeeForm" asp-action="EditDisclosureFeeDetail" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" asp-for="Request.RequestId" value="@Model.Request.RequestId" />
                                    <input type="hidden" asp-for="Disclosure.DisclosureId" value="@Model.Disclosure.DisclosureId" />
                                    <input type="hidden" name="DisclosureFeeDetails.Index" value="@i" />
                                    <input type="hidden" name="DisclosureFeeDetails[@i].DisclosureFeeTypeId" value="@feeDetail.DisclosureFeeTypeId" />
                                    
                                    
                                    <tr id="editDisclosureFee">
                                        <td>
                                            <select asp-for="DisclosureFeeDetails[i].DisclosureFeeTypeId"
                                                id="disclosureFeeAmount"
                                                asp-items="@Model.DisclosureFeeAmounts" required disabled>
                                            </select>
                                        </td>
                                        <td>
                                            <select asp-for="DisclosureFeeDetails[i].DisclosureFeeTypeId"
                                                id="disclosureFeeDescription"
                                                asp-items="@Model.DisclosureFeeDescriptions" required>
                                            </select>
                                        </td>
                                        <td>
                                            <select asp-for="DisclosureFeeDetails[i].DisclosureFeeTypeId"
                                                id="disclosureFeeComment"
                                                asp-items="@Model.DisclosureFeeComments" required disabled>
                                            </select>
                                        </td>
                                        <td>
                                            <input type="text" class="form-control"  name="DisclosureFeeDetails[@i].ItemCount" value="@feeDetail.ItemCount" />
                                        </td>
                                        <td>@(feeDetail.ItemCount * feeDetail.PerItemFee)</td>
                                        <td class="d-flex border border-1">
                                            <input type="submit" value="Save" class="btn btn-success text-white" style="margin-right: 4px; border:none;" />
                                            
                                            <a asp-action="DisclosureDetails"
                                                asp-route-id="@Model.Request.RequestId"
                                                class="btn btn-secondary text-white"
                                                style="border:none;">
                                                    Cancel
                                            </a>
                                        </td>
                                    </tr>
                                </form>
                            }
                            <div hidden>
                                @(subtotal = subtotal + (feeDetail.PerItemFee * feeDetail.ItemCount));
                            </div>
                        }

                        <!-- Add Fee table using the <thead> from above but separate <form> -->
                        <form id="addFeeForm" asp-action="AddDisclosureFeeDetail" method="post">
                            @Html.AntiForgeryToken()
                            <tr id="addDisclosureFee" style="display:none">
                                <td><input type="hidden" asp-for="Request.RequestId" value="@Model.Request.RequestId" />
                                    <input type="hidden" asp-for="Disclosure.DisclosureId" value="@Model.Disclosure.DisclosureId" />

                                    <select asp-for="DisclosureFeeType.DisclosureFeeTypeId" 
                                            id="disclosureFeeAmount" 
                                            asp-items="@Model.DisclosureFeeAmounts" required disabled>
                                            <option value="">Select</option>
                                    </select>
                                </td>
                                <td>
                                    <select asp-for="DisclosureFeeType.DisclosureFeeTypeId" 
                                            id="disclosureFeeDescription" 
                                            asp-items="@Model.DisclosureFeeDescriptions" required>
                                        <option value="">Select</option>
                                    </select>
                                </td>
                                <td>
                                    <select asp-for="DisclosureFeeType.DisclosureFeeTypeId" 
                                            id="disclosureFeeComment" 
                                            asp-items="@Model.DisclosureFeeComments" required disabled>
                                        <option value="">Select</option>
                                    </select>
                                </td>
                                <td><input type="number" id="itemCount" name="DisclosureFeeDetails[0].ItemCount" class="form-control" /></td>
                                <td> <input type="text" id="itemTotal" name="DisclosureFeeDetails[0].ItemTotal" class="form-control" readonly /></td>
                                <td class="d-flex">
                                    <button type="submit" class="btn btn-success text-white" style="margin-right: 4px;">Save</button>
                                    <button type="button" class="btn btn-secondary text-white" onclick="toggleAddFee()">Cancel</button>
                                </td>
                            </tr>
                        </form>
                    </tbody>
                </table>
                
                <div class="subtotal-row" @(subtotal == 0 ? "hidden" : "")>
                    <div class="subtotal-label">Subtotal:</div>
                    <div class="subtotal-value" id="subtotalValue">$@(ViewBag.Subtotal != null ? ViewBag.Subtotal.ToString("0.00") : "")</div>
                </div>
                <div class="subtotal-row sales-tax-row" @(subtotal == 0 ? "hidden" : "")>
                    <div class="subtotal-label">Sales Tax:</div>
                    <div class="subtotal-value" id="salesTaxValue">$@(ViewBag.CalculatedSalesTax != null ? ViewBag.CalculatedSalesTax.ToString("0.00") : "")</div>
                </div>
                <div class="subtotal-row mt-1" @(subtotal == 0 ? "hidden" : "")>
                    <div class="subtotal-label">Invoice Total:</div>
                    <div class="subtotal-value" id="invoiceTotalValue">$@Model.Disclosure.InvoiceTotal</div>
                </div>
                <hr class="double-line"/>
            </div>
        </div>
        

        <!--Payment Table-->
        <div class="card-body bg-light">
            <div class="container">
                <h5 class="col-12 bg-primary py-3 text-light font-weight-bold d-flex justify-content-between align-items-center">
                    Payments
                    @if (userPermissions != null && (userPermissions.Contains("DisclosureRequestEdit")) )
                    {
                        <button type="button" class="btn btn-outline-success" id="addDisclosurePaymentBtn" onclick="toggleAddPayment()">

                            <i class="fas fa-plus"></i> Add Payment
                        </button>
                    }
                </h5>
                <table class="table table-striped table-bordered">
                    <thead class="bg-primary text-white">
                        <tr> 
                            <th>Payment Date</th>
                            <th>Payment Amount</th>
                            <th>Payment Type</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model.Disclosure.DisclosurePayments)
                        {
                            @if(item.DisclosurePaymentId != Model.DisclosurePaymentBeingEditedId)
                            {
                                <tr>
                                    <td>@item.PaymentDate.ToShortDateString()</td>
                                    <td>$@item.PaymentAmount</td>
                                    <td>@item.PaymentType.PaymentType1</td>
                                    <td>
                                        @if (userPermissions != null && (userPermissions.Contains("DisclosureRequestEdit")) )
                                        {
                                            <a asp-action="EnableEditDisclosurePayment"
                                               asp-route-disclosurePaymentId="@item.DisclosurePaymentId"
                                               asp-route-disclosureId="@Model.Disclosure.DisclosureId"
                                               asp-route-requestId="@Model.Request.RequestId"
                                               class="btn btn-info text-white"
                                               style="margin-right: 4px;">
                                                Edit
                                            </a>
                                            <a onclick="return confirm('Are you sure you want to delete this item?')"
                                               asp-action="DeleteDisclosurePayment"
                                               asp-route-disclosurePaymentId="@item.DisclosurePaymentId"
                                               asp-route-requestId="@Model.Request.RequestId"
                                               class="btn btn-danger text-white">
                                                Delete
                                            </a>
                                        }
                                    </td>
                                </tr>
                            } else
                            {
                                <!--Edit Disclosure Payment-->
                                <form method="post" asp-action="EditDisclosurePayment">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" asp-for="Request.RequestId" value="@Model.Request.RequestId" />
                                    <input type="hidden" asp-for="DisclosurePaymentBeingEdited.DisclosureId" value="@Model.Disclosure.DisclosureId" />
                                    <input type="hidden" asp-for="DisclosurePaymentBeingEditedId" value="@Model.DisclosurePaymentBeingEditedId" />
                                    <tr id="addDisclosurePayment">
                                        <td>
                                            <input asp-for="DisclosurePaymentBeingEdited.PaymentDate" type="date" class="form-control" />
                                        </td>
                                        <td>
                                            <input asp-for="DisclosurePaymentBeingEdited.PaymentAmount" type="number" class="form-control" step="0.01" />
                                        </td>
                                        <td>
                                            <select asp-for="DisclosurePaymentBeingEdited.PaymentTypeId" asp-items="@Model.PaymentTypes" class="form-control"></select>
                                        </td>
                                        <td class="d-flex">
                                            <button type="submit" class="btn btn-success text-white" style="margin-right: 4px;">Save</button>
                                            <a class="btn btn-secondary text-white" asp-action="DisableEditDisclosurePayment" asp-route-requestId="@Model.Request.RequestId">Cancel</a>
                                        </td>
                                    </tr>
                                </form>
                            }
                        } 
                        <!-- Add Payment Form -->
                        <form method="post" asp-action="AddDisclosurePayment">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Request.RequestId" value="@Model.Request.RequestId" />
                            <input type="hidden" asp-for="DisclosurePayment.DisclosureId" value="@Model.Disclosure.DisclosureId" />
                            <tr id="addDisclosurePayment" style="display:none">
                                <td>
                                    <input asp-for="DisclosurePayment.PaymentDate" type="date" class="form-control" />
                                </td>
                                <td>
                                    <input asp-for="DisclosurePayment.PaymentAmount" type="number" class="form-control" step="0.01" />
                                </td>
                                <td>
                                    <select asp-for="DisclosurePayment.PaymentTypeId" asp-items="@Model.PaymentTypes" class="form-control"></select>
                                </td>
                                <td class="d-flex">
                                    <button type="submit" class="btn btn-success text-white" style="margin-right: 4px;">Save</button>
                                    <button type="button" class="btn btn-secondary text-white" onclick="toggleAddPayment()">Cancel</button>
                                </td>
                            </tr>
                        </form>
                    </tbody>
                </table>
            </div>
        </div>

    }
    else
    {
        <!--View Mode If there isn't a disclosure-->
        <div class="card-body bg-light" id="viewMode">
            <div class="container">
                <div class="row" >
                    <div class="col-12">
                        <h5>No Invoice Information Available</h5>
                    </div>
                </div>
            </div>
        </div>

        <!--Add Disclosure View-->             
        <form method="post" id="addMode" style="display:none;" asp-action="AddDisclosure">
            @Html.AntiForgeryToken()
            <input type="hidden" value="@Model.Request.RequestId" asp-for="Request.RequestId" />
            <input type="hidden" value="@Model.Requester.RequesterId" asp-for="Requester.RequesterId" />
            <div class="card-body bg-light">
                <div class="container">
                    <div class="row">
                        <div class="col-4 d-flex">
                            <div><label class="mt-1">Disclosure Date: </label></div>
                            <div class="mx-2">
                                <input asp-for="@Model.DisclosureBeingEdited.DisclosureDate"
                                        type="date"                                        
                                        class="form-control" />
                            </div>
                        </div>
                        <div class="col-4 d-flex">
                            <div><label class="mt-1">Invoice Date: </label></div>
                            <div class="mx-2">
                                <input asp-for="@Model.DisclosureBeingEdited.InvoiceDate"
                                        type="date"                                      
                                        class="form-control" />
                            </div>
                        </div>
                        <div class="col-4 d-flex">
                            <div><label class="mt-1" style="color: #808080;">Invoice Number: </label></div>
                        </div>
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-4 d-flex">
                            <div>
                                <label class="mt-1">Pre-Payment Required: </label>
                            </div>
                            <div class="mx-2">
                                <select asp-for="@Model.DisclosureBeingEdited.IsPaymentRequired" class="form-control">
                                    <option>Select</option>
                                    <option value="true">Yes</option>
                                    <option value="false">No</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-4 d-flex">
                            <div><label class="mt-1">Comments: </label></div>
                            <div class="mx-2">
                                <input asp-for="@Model.DisclosureBeingEdited.Comments"
                                        type="text"
                                        class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <button class="btn btn-primary btn-block" id="saveBtn" type="submit" style="display:none">Add Invoice</button>
            <a class="btn btn-secondary text-white mt-3 float-right"
               id="cancelBtn"
               onclick="toggleAdd(); return confirm('Are you sure you want to Cancel? All changes will be lost.')"
               asp-action="DisclosureDetails"
               style="display:none">Cancel</a>
        </form>
    }
</div>

<style>
   .double-line {
        border: 0;
        border-top: 3px double #b3b1b1; /* Adjust the color and thickness */
        margin: 20px 0; /* Adjust the spacing to other objects;  currently the same as a single line */
    }

    .fee-column { width: 10%; } /* percentages are based upon the table's width */
    .description-column { width: 20%; }
    .comments-column { width: 30%; }
    .item-count-column { width: 10%; }
    .total-fee-column { width: 10%; }
    .action-column { width: 20%; }

    /* set explicit width styles to items initially hidden to enforce the table style when visible */
    #addDisclosureFee td {
        width: auto; /* let the table columns determine width */
        white-space: nowrap; /* Prevent overflowing */
    }

    /* enforce sizing to the parent <td> */
    input, select {
        width: 100%;
        box-sizing: border-box; /* ensure padding/borders fit within column width */
    }

    .subtotal-row {
        display: flex;
        padding: 0px 0;
    }

    .subtotal-label {
        flex: 0 0 70%; /* Adjust according to the table columns' widths */
        text-align: right;
        padding-right: 15px;
    }

    .subtotal-value {
        flex: 0 0 10%; /* Adjust according to the table columns' widths */
        text-align: right;
        padding-right: 20px;
        position: relative;
    }

    .sales-tax-row .subtotal-value::after { 
        content: ""; 
        position: absolute; 
        top: 100%; /* Position the line below the text */
        left: -120px; /* Align with the padding of subtotal-label */
        right: 0; 
        height: 2px; /* Adjust the thickness of the line */
        background: black; /* The color of the line */
        margin-top: 0px; /* Optional: add margin to create space below the line */
    }

    thead th {
        text-align: center;
    }

    /* Center align the contents of specific columns of the Fee Table only */
    #feeTable tbody tr td:nth-child(1), /* First column */
    #feeTable tbody tr td:nth-child(4) { /* Fourth column */
        text-align: center;
    }

    /* Right align the contents of the fifth column with padding */
    #feeTable tbody tr td:nth-child(5) {
        text-align: right;
        padding-right: 20px; /* Adjust the padding value as needed */
    }

</style>

@section Scripts {
    <script>

        $(document).ready(function() {
            // When any select dropdown changes
            $('select').change(function() {
                // Get the value of the changed select input
                var changedValue = $(this).val();

                // Update the other select inputs with the same value
                $('#disclosureFeeAmount').val(changedValue);
                $('#disclosureFeeDescription').val(changedValue);
                $('#disclosureFeeComment').val(changedValue);
                $('#disclosureFeeEffectiveDate').val(changedValue);
                $('#disclosureFeeExpirationDate').val(changedValue);
            });
        });

        let editDisclosure = false;

        function toggleEdit() {
            editDisclosure = !editDisclosure;

            // Toggle visibility using jQuery
            if (editDisclosure) {
                $("#viewMode").hide();
                $("#editMode").show();
                $("#editBtn").hide();
                $("#cancelBtn").show();
                $("#saveBtn").show();
            } else {
                $("#viewMode").show();
                $("#editMode").hide();
                $("#editBtn").show();
                $("#cancelBtn").hide();
                $("#saveBtn").hide();
            }
        }

        let addDisclosure = false;

        function toggleAdd() {
            addDisclosure = !addDisclosure;

            if (addDisclosure) {
                $("#viewMode").hide();
                $("#addMode").show();
                $("#addBtn").hide();
                $("#cancelBtn").show();
                $("#saveBtn").show();
            } else {
                $("#viewMode").show();
                $("#addMode").hide();
                $("#addBtn").show();
                $("#cancelBtn").hide();
                $("#saveBtn").hide();
            }
        }

        let addPayment = false;

        function toggleAddPayment() {
            addPayment = !addPayment;

            if (addPayment) {
                $("#addDisclosurePaymentBtn").hide();
                $("#addDisclosurePayment").show();
            } else {
                $("#addDisclosurePaymentBtn").show();
                $("#addDisclosurePayment").hide();
            }
        }

         let addFee = false;

        function toggleAddFee() {
            addFee = !addFee;

            if (addFee) {
                $("#addDisclosureFeeBtn").hide();
                $("#addDisclosureFee").show();
            } else {
                $("#addDisclosureFeeBtn").show();
                $("#addDisclosureFee").hide();
            }
        }
    </script>
}