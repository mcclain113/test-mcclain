@model IS_Proj_HIT.Entities.Patient
<style>
  .btn-link {
    text-align: left !important;
    white-space: normal !important; /* Allows wrapping */
    display: block; /* Ensures full width */
}

/* remove border/shadow between the main header and the nested card-header inside the collapse */
#headingOne.card-header {
  border-bottom: 0 !important;
  box-shadow: none !important;
}

/* the nested card-header inside the collapse (the submenu container) */
#administrationCollapse > .card-header,
#administrationCollapse .card-header {
  border-top: 0 !important;
  border-bottom: 0 !important;
  box-shadow: none !important;
  @* background: transparent !important; *@
  padding-top: 0 !important;
  padding-bottom: 0 !important;
}
</style>

  <div class="card col-2 mx-0 px-0 float-left">
    <div class="card-header bg-primary text-white">
      <h4>
        Patient Menu
      </h4>
      
        @* If the ViewBag has a returnToEncouterId, overrides the button to return to encounter instead of patient *@
        @if (@ViewBag.returnToEncouterId != null)
        {
            <a asp-controller="Encounter" asp-action="ViewEncounter" asp-route-encounterId="@ViewBag.returnToEncounterId" class="text-white">
                <small>Return to Encounter</small>
            </a>
        } else {
            <a asp-controller="Patient" asp-action="ViewPatientDetails" asp-route-id="@Model.Mrn" class="text-white">
                <small>Return to Patient</small>
            </a>
        }

    </div>

    @* To 'undisable' a button, remove 'disabled' from <button class="btn btn-link collapsed disabled"  *@
    <div id="accordion" class="accordion accordion-flush mx-0 px-0">
      <div class="card">
        <div class="card-header" id="headingThree">
          <h5 class="mb-0">
                <a asp-controller="Patient" asp-action="ListAlerts" asp-route-mrn="@Model.Mrn" id="listAlerts" class="btn btn-link menuLink">
                  ALERTS
                </a>
          </h5>
        </div>
      </div>

      <div class="card">
        <div class="card-header" id="headingTwo">
          <h5 class="mb-0">
              <a asp-controller="Patient" asp-action="ListAllergies" asp-route-mrn="@Model.Mrn" id="allergies" class="btn btn-link menuLink">
                ALLERGIES 
              </a>
          </h5>
        </div>
      </div>

      <div class="card">
        <div class="card-header" id="headingFour">
          <h5 class="mb-0">
              <a asp-controller="Patient" asp-action="ListMedications" asp-route-id="@Model.Mrn" id="listMedications" class="btn btn-link menuLink">
                MEDICATIONS
              </a>
          </h5>
        </div>
      </div>

      <div class="card">
        <div class="card-header" id="headingFive">
          <h5 class="mb-0">
            <a asp-controller="Patient" asp-action="" asp-route-id="" id="problemList" class="btn btn-link menuLink disabled">
              PROBLEM LIST
            </a>
          </h5>
        </div>
      </div>

      <div class="card">
        <div class="card-header" id="headingSix">
          <h5 class="mb-0">
            <a asp-controller="Patient" asp-action="" asp-route-id="" id="vaccinations" class="btn btn-link menuLink disabled">
              VACCINATIONS
            </a>
          </h5>
        </div>
      </div>

      <div class="card">
        <div class="card-header" id="headingZero">
          <h5 class="mb-0">
            <a asp-controller="Document" asp-action="ViewDocuments" asp-route-mrn="@Model.Mrn" id="patientDocuments" class="btn btn-link menuLink">
              PATIENT DOCUMENTS
            </a>
          </h5>
        </div>
      </div>

      <div class="card">
        <div class="card-header" id="headingOne">
          <h5 class="mb-0">
            <button class="btn menuLink collapsed" data-toggle="collapse"
              data-target="#administrationCollapse" aria-expanded="false" aria-controls="administrationCollapse"
              id="administration">
              <span class="menuText mr-5">ADMINISTRATION</span>
              <i class="fas fa-chevron-down submenu-caret" aria-hidden="true"></i>
            </button>
          </h5>
        </div>
        <div id="administrationCollapse" class="collapse" aria-labelledby="headingOne" data-parent="#accordion">
          <div class="card-header m-0 p-0">
            <div class="btn-group-vertical btn-block">
              <ul class="menuListBullet ml-3">
                <li>
                  <a class="btn btn-link menuLink menuListItem disabled" asp-controller=""
                    asp-action="" asp-route-id="" style="text-align:left"
                    id="appointments"> Appointments</a>
                </li>
                <li>
                  <a class="btn btn-link menuLink menuListItem disabled" asp-controller=""
                    asp-action="" asp-route-id="" style="text-align:left"
                    id="correspondence">Correspondence</a>
                </li>
                <li>
                  <a class="btn btn-link menuLink menuListItem disabled" asp-controller="" asp-action=""
                    style="text-align:left" id="claimsBilling"> Claims/Billing</a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>


@{
  var currentActionName = ViewContext.RouteData.Values["action"].ToString();
}

<script>
$(document).ready(function(){
    if ('@currentActionName' === 'ViewDocuments') {
        $('#patientDocuments').removeClass('menuLink').addClass('activeMenuLink');
    } else if ('@currentActionName' === 'ListAllergies') {
        $('#allergies').removeClass('menuLink').addClass('activeMenuLink');
    } else if ('@currentActionName' === 'ListAlerts') {
        $('#listAlerts').removeClass('menuLink').addClass('activeMenuLink');
    } else if ('@currentActionName' === 'ListMedications') {
        $('#listMedications').removeClass('menuLink').addClass('activeMenuLink');
    } else if ('@currentActionName' === 'ProblemList') {
        $('#problemList').removeClass('menuLink').addClass('activeMenuLink');
    } else if ('@currentActionName' === 'Appointments') {
        $('#appointments').removeClass('menuLink').addClass('activeMenuLink');
    } else if ('@currentActionName' === 'Correspondence') {
        $('#correspondence').removeClass('menuLink').addClass('activeMenuLink');
    } else if ('@currentActionName' === 'ClaimsBilling') {
        $('#claimsBilling').removeClass('menuLink').addClass('activeMenuLink');
    }
});
    </script>
