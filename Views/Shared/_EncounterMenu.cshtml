@model IS_Proj_HIT.Entities.Encounter
<style>
  /* selector for the menu card wrapper */
  .encounter-menu-wrapper {
    overflow-y: auto;
    -webkit-overflow-scrolling: touch; /* smooth scrolling on iOS */
    max-height: calc(100vh - var(--encounter-menu-vertical-offset, 200px));
  }
  .btn-link {
    text-align: left !important;
    white-space: normal !important; /* Allows wrapping */
    display: block; /* Ensures full width */
  }

  .menuButton{
      width:100%; 
      display:flex;  
      align-items:center; 
      justify-content:space-between; 
      padding-right:1rem;
  }

  .menuText{
      flex:1; 
      text-align:left; 
      white-space:normal;
  }

  .submenu-caret{
      flex:0 0 auto; 
      margin-left:0.5rem;
  }

  /* keep dialog centered to the viewport */
  /* Set modal width to 75% of viewport */
  #globalModal .modal-dialog {
    position: fixed;  /* positions the dialog to the viewport instead of the container */
    min-width: 75vw;  /* forces the width regardless of what the content might require so columns aren't collapsed  */
    left: 50%;  /* these two center the top left corner of the dialog  */
    top: 50%;
    transform: translate(-50%, -50%); /* translate back and up to center based upon dialog center point  */
  }

  #globalModalBody { 
    max-height: calc(100vh - 100px); 
    overflow-y: auto; 
  }

  .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem;
      border-bottom: 1px solid #dee2e6;
      background-color: #f8f9fa;
  }

  .modal-title {
      margin: 0;
      color: #000;
  }

  /* Ensure modal content does not overflow horizontally */
  #globalModal .modal-content {
    overflow-wrap: break-word;
  }

  /* For very small screens, fall back to full width with margins */
  @@media (max-width: 576px) {
    #globalModal .modal-dialog {
      max-width: calc(100vw - 1rem);
      margin: 0.5rem;
    }
  }
</style>

