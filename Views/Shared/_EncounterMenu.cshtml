<!-- Global modal: single instance for all sidebar links -->
<div class="modal fade" id="globalModal" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="globalModalTitle">
  <div class="modal-dialog" role="document"> 
    <div class="modal-content">
