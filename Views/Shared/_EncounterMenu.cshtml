          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body" id="globalModalBody">
        <!-- Partial view content will be injected here -->
      </div>
    </div>
  </div>
</div>
@using System.Text.Json
@{
  var currentActionName = ViewContext.RouteData.Values["action"].ToString();
  var docTypeValue = ViewContext.RouteData.Values["docType"]?.ToString()
                     ?? Context.Request.Query["docType"].ToString()
                     ?? "";
}

<script>
  $(document).ready(function () {
    var docType = @Html.Raw(JsonSerializer.Serialize(docTypeValue));

    checkForPhysicianAssessment();

    if ('@currentActionName' === 'ViewHistoryAndPhysical') {
      $('#historyAndPhysical').removeClass('menuLink').addClass('activeMenuLink');
      $('#physicianDocumentsCollapse').removeClass('collapse');
    } else if ('@currentActionName' === 'ViewPhysicianDischarge') {
      $('#viewPhysicianDischarge').removeClass('menuLink').addClass('activeMenuLink');
      $('#physicianDocumentsCollapse').removeClass('collapse');
    } else if ('@currentActionName' === 'ListOrders') {
      $('#listOrders').removeClass('menuLink').addClass('activeMenuLink');
    } else if ('@currentActionName' === 'Medications') {
      $('#medications').removeClass('menuLink').addClass('activeMenuLink');
    } else if ('@currentActionName' === 'PCAIndex') {
      $('#pcaIndex').removeClass('menuLink').addClass('activeMenuLink');
      $('#nursingCollapse').removeClass('collapse');
    } else if ('@currentActionName' === 'ViewDocuments') {
      // Try to find a child link matching the docType first (because it is in the LABS & DIAGNOSTICS card)
      var $child = null;
      if (docType) {
        // select by data attribute (recommended). Ensure child anchors have data-doctype="4" etc.
        $child = $('a[data-doctype="' + docType + '"]');
      }
      if ($child && $child.length) {
        // mark only the specific child as active and open its accordion
        $child.removeClass('menuLink').addClass('activeMenuLink');
        $('#labDiagnosticsCollapse').removeClass('collapse');
      } else {
        // no matching child found -> mark the top-level encounterDocuments active (because it is the ENCOUNTER DOCUMENTS card)
        var $enc = $('#encounterDocuments');
        if ($enc.length) {
          $enc.removeClass('menuLink').addClass('activeMenuLink');
        }
      }
    } else if ('@currentActionName' === 'ProgressNotes') {
      $('#integratedNotes').removeClass('menuLink').addClass('activeMenuLink');
    }

    $('#physician').on('click', function (e) {
      checkForPhysicianAssessment();
    });

    function checkForPhysicianAssessment() {
      var link = document.getElementById('viewPhysicianDischarge');
      var encounterId = @Model.EncounterId;
      var historyAndPhysicalId = "";
      $.ajax({
        type: "GET",
        url: "/Encounter/GetHistoryAndPhysicalStatus",
        dataType: "json",
        data: { id: encounterId },
        success: function (result) {
          historyAndPhysicalId = parseInt(result.historyAndPhysicalId);

          if (historyAndPhysicalId > 0) {
            link.setAttribute("class", "btn btn-link menuLink menuListItem enabled");
            if ('@currentActionName' === 'ViewPhysicianDischarge') {
              $('#viewPhysicianDischarge').removeClass('menuLink').addClass('activeMenuLink');
            }
          }
          else {
            link.setAttribute("class", "btn btn-link menuLink menuListItem disabled");
          }
        },
        error: function (error) {
          console.log(`Error ${error}`);
          link.setAttribute("class", "btn btn-link menuLink menuListItem disabled");
        }
      })
    };

  });
</script>

<!-- js to handle display of any card in the global modal: list, details, edit -->
<script>
  $(function () {
    var $doc = $(document);
    var $modal = $('#globalModal');
    var $modalBody = $modal.find('#globalModalBody');
    var $modalTitle = $modal.find('#globalModalTitle');

    function showLoading(title) {
      $modalTitle.text(title || 'Loading...');
      $modalBody.html('<div class="text-center p-4"><div class="spinner-border" role="status" aria-hidden="true"></div></div>');
      $modal.modal('show');
    }

    // helper to set/remove background inert/aria-hidden
    function setBackgroundHidden(hidden) {
      var modal = document.getElementById('globalModal');
      var siblings = Array.prototype.slice.call(document.body.children).filter(function (el) {
        return el !== modal;
      });
      if ('inert' in HTMLElement.prototype) {
        siblings.forEach(function (el) { el.inert = hidden; });
      } else {
        siblings.forEach(function (el) {
          if (hidden) el.setAttribute('aria-hidden', 'true'); else el.removeAttribute('aria-hidden');
        });
      }
    }

    function adjustDataTables() {
      if (!$.fn.DataTable) return;
      setTimeout(function () {
        try {
          $.each($.fn.dataTable.tables(true), function (i, table) {
            var dt = $(table).DataTable();
            dt.columns.adjust();
            if (dt.responsive) dt.responsive.recalc();
          });
        } catch (ex) { }
      }, 50);
    }

    function setModalTitleFromContent(defaultTitle) {
      var provided = $modalBody.find('[data-modal-title]').data('modalTitle');
      $modalTitle.text(provided || defaultTitle || '');
    }

    // Generic delegated link handler for opening any sidebar card into modal
    $doc.on('click', 'a.open-in-modal, a.open-create, a.open-edit, a.open-details, a.back-to-list', function (e) {
      var $link = $(this);
      var url = $link.attr('href');
      if (!url) return true;
      if ($modal.length === 0) return true;

      e.preventDefault();
      showLoading($link.data('modalTitle') || $link.attr('title') || 'Loading...');

      $.ajax({
        url: url,
        method: 'GET',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        success: function (html) {
          $modalBody.html(html);
          // init select2 inside the injected partial so dropdown is appended to modal and doesn't fall behind the modal
          $modalBody.find('.meds-select2').select2({
            width: '100%',
            dropdownParent: $modalBody
          });
          setModalTitleFromContent($link.data('modalTitle') || 'Details');
          adjustDataTables();
          $modalBody.attr('tabindex', '-1').focus();
        },
        error: function () {
          $modalBody.html('<div class="text-danger p-3">Failed to load content.</div>');
          $modalTitle.text('Error');
        }
      });
    });

    // Delegated form submit handler for forms inside the modal body
    $doc.on('submit', '#globalModalBody form', function (e) {
      var $form = $(this);
      if ($modal.length === 0) return true;

      e.preventDefault();
      var url = $form.attr('action') || window.location.href;
      var method = ($form.attr('method') || 'POST').toUpperCase();
      var hasFile = $form.find('input[type=file]').length > 0;
      var data, processData = true, contentType = 'application/x-www-form-urlencoded; charset=UTF-8';

      if (hasFile) {
        data = new FormData($form[0]);
        processData = false;
        contentType = false;
      } else {
        data = $form.serialize();
      }

      var $overlay = $('<div class="modal-loading-overlay" style="position:absolute;left:0;right:0;top:0;bottom:0;background:rgba(255,255,255,.6);z-index:1000;"><div class="spinner-border" role="status" aria-hidden="true"></div></div>');
      $modalBody.css('position', 'relative').prepend($overlay);

      $.ajax({
        url: url,
        method: method,
        data: data,
        processData: processData,
        contentType: contentType,
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        success: function (response, status, xhr) {
          var ct = (xhr.getResponseHeader('Content-Type') || '').toLowerCase();

          if (ct.indexOf('application/json') !== -1) {
            var json = (typeof response === 'string') ? JSON.parse(response) : response;
            if (json && json.success && json.redirectUrl) {
              $.ajax({
                url: json.redirectUrl,
                method: 'GET',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                success: function (html) {
                  $modalBody.html(html);
                  setModalTitleFromContent('Details');
                  adjustDataTables();
                },
                error: function () {
                  $modal.modal('hide');
                  window.location = json.redirectUrl;
                }
              });
              return;
            }
            if (json && json.success && json.closeModal) {
              $modal.modal('hide');
              if (json.reloadPage) window.location.reload();
              return;
            }
          }

          $modalBody.html(response);
          setModalTitleFromContent('Details');
          adjustDataTables();
          $modalBody.attr('tabindex', '-1').focus();
        },
        error: function (xhr) {
          var msg = 'Failed to save changes.';
          if (xhr && xhr.responseText) msg += ' ' + xhr.responseText;
          var $alert = $('<div class="alert alert-danger"></div>').text(msg);
          $modalBody.prepend($alert);
        },
        complete: function () {
          $overlay.remove();
        }
      });
    });

    // Clear modal content on hide
    $modal.on('hidden.bs.modal', function () {
      $modalBody.empty().removeAttr('tabindex');
      $modalTitle.empty();
    });

    // Refresh patient alert button(s) after any global modal closes
    $('#globalModal').on('hidden.bs.modal', function () {
      try {
        // Acquire MRN: prefer body data attribute to avoid touching many views
        var mrn = $('body').data('current-mrn') || '@(Model?.Mrn ?? "")';
        if (!mrn) return;

        $.ajax({
          url: '/Patient/GetAlertSummary',
          method: 'GET',
          data: { mrn: mrn },
          dataType: 'json',
          success: function (data) {
            if (!data) return;

            // Update existing alert button(s) in-place.
            // Primary selector uses id from your partial; also update any anchor with href containing ListAlerts?mrn=
            var $btn = $('#listAlertsButton');
            if ($btn.length === 0) {
              // fallback: find any link that points to ListAlerts for this MRN
              $btn = $('a[href*="/Patient/ListAlerts"][href*="' + mrn + '"]').first();
            }

            if ($btn.length) {
              // Adjust class based on whether there are active alerts
              var hasActive = data.hasActive === true;
              var newClass = hasActive ? 'btn btn-outline-danger' : 'btn btn-outline-warning';
              $btn.removeClass('btn-outline-danger btn-outline-warning').addClass(newClass);

              // Replace the inner count text. Keep icon and other markup if present.
              // Strategy: find an element holding "Alerts X" text, else replace button text
              var html = $btn.html();
              // Simple regex approach: replace the "Alerts N" portion if present
              // This expects markup similar to: <h5 ...><i ...></i> Alerts N</h5>
              html = html.replace(/Alerts\s*\d+/i, 'Alerts ' + (data.activeAlerts || 0));
              // If regex didn't match, append count safely
              if (!/Alerts\s*\d+/i.test($btn.html())) {
                // try to append inside a heading
                var $h = $btn.find('h5').first();
                if ($h.length) {
                  $h.text($h.text().trim() + ' Alerts ' + (data.activeAlerts || 0));
                } else {
                  $btn.text('Alerts ' + (data.activeAlerts || 0));
                }
              } else {
                $btn.html(html);
              }
            }

            // If you have other places that need updating (e.g., small banner text elsewhere),
            // locate them by a consistent selector/data attribute and update similarly.
          },
          error: function () {
            // silent fail: keep current banner if refresh fails
          }
        });
      } catch (e) {
        // ignore
      }
    });
  });
</script>

<script>
  (function () {
    var key = 'encounterMenuScroll';

    // save current scroll position when a menu link is clicked
    $('.encounter-menu-wrapper').on('click', 'a', function () {
      try {
        sessionStorage.setItem(key, $('.encounter-menu-wrapper').scrollTop());
      } catch (e) {}
    });

    // also save on page unload (safety)
    window.addEventListener('beforeunload', function () {
      try {
        sessionStorage.setItem(key, $('.encounter-menu-wrapper').scrollTop());
      } catch (e) {}
    });

    // restore when DOM is ready (small delay to ensure layout is stable)
    $(function () {
      try {
        var val = sessionStorage.getItem(key);
        if (val !== null) {
          var st = parseInt(val, 10);
          if (!isNaN(st)) {
            // use a frame or timeout to let things paint (tweak delay if needed)
            requestAnimationFrame(function restore() {
              var $wrap = $('.encounter-menu-wrapper');
              if ($wrap.length) {
                $wrap.scrollTop(st);
              }
            });
          }
        }
      } catch (e) {}
    });
  })();
</script>