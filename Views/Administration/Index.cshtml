@{
    ViewBag.Title = "Administration";
    var userPermissions = ViewData["UserPermissions"] as List<string>;
    var requiredStructuredDataPermissions = new[]{"StructuredDataAdd","StructuredDataEdit","StructuredDataView","StructuredDataDelete"};
    var requiredSecurityPermissions = new[]{"SecurityAssignRole","SecurityRemoveRole"};
}

<div class="row my-3">
    <div class="col-12">
        <h3>Administration Tools</h3>
    </div>
</div>

