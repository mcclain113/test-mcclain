        {
            <div class="col-sm-3 mb-3">
                <div class="card">
                    <div class="card-body">
                        <a asp-controller="AlertStructuredData" asp-action="Index" class="btn btn-outline-primary">
                            <h5 class="card-title mb-0">Alert Structured Data</h5>
                        </a>
                    </div>
                    <div class="card-footer">
                        <p class="mb-0">Management pages for Alert structured data/lookup tables  </p>
                    </div>
                </div>
