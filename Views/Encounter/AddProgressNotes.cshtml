@model IS_Proj_HIT.ViewModels.ProgressNotesViewModel
@{
    ViewData["Title"] = "Add Physician Notes";
    var signer = ViewBag.Providers;
    var coSigner = ViewBag.Cosigners;
}

<partial model="ViewBag.Patient" name="PatientBannerPartial" />
<partial name="_EncounterMenu" model="Model.Encounter"/>
<partial model="_ValidationScriptsPartial"/>

<div class="card">
    <div class="card-header bg-primary text-white">
        <h4>
            Add Integrated Progress Note
        </h4>
    </div>
    <div class="card-body bg-light">
        <div class="container" asp-validation-summary="All">
            <form method="post" id="progressNote" name="progressNote" asp-action="AddProgressNotes">
                @Html.AntiForgeryToken()
                <div class="row mt-3">
                    <div class="col-12 col-lg-6">
                        <input type="hidden" asp-for="@Model.EncounterId" value="@ViewBag.EncounterId" />
                        
                        <div class="row mb-3 form-group">
                            <label for="noteType" class="col-sm-4 col-form-label" >Note Type: </label>
                            <div class="col-sm-8">
                                <select id="noteType" asp-for="@Model.NoteTypeId"
                                        name="NoteTypeId" class="form-control form-select" asp-items="ViewBag.NoteTypes" required>
                                    <option value="">Select a Note Type</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="row mb-3 form-group">
                            <label for="date" class="col-sm-4 col-form-label">Note Date: </label>
                            <div class="col-sm-8">
                                <input type="datetime-local"  asp-for="@Model.WrittenDate" name="WrittenDate"
                                    class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                                    id="date"/>
                            </div>
                        </div>
                    </div>
                </div>
                <hr/>

                <div class="row">
                    <div class="col">
                        <div class="form-group">
                            <label style="">Physician Note:</label>
                            <div class="col-sm-12">
                                <textarea asp-for="@Model.Note" style="width: 100%;" rows="4" id="editor"
                                    required></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <hr/>
                        
                <div class="row">
                    <div class="col-12 col-lg-6">
                        <div class="row form-group">
                            <label for="physician" class="col-sm-4 col-form-label">Authoring Provider: </label>
                            <div class="col-sm-8 justify-content-center">
                                <select id="physician" class="form-control dropdowns selectable sign"
                                    asp-for="@Model.PhysicianId" asp-items="signer" name="PhysicianId" required>
                                    <option value="">Select a Provider</option>
                                </select>
                            </div>
                        </div>
                        <div class="row form-group">
                            <label for="providersignature" class="col-sm-4 col-form-label">Provider Signature: </label>
                            <div class="col-sm-8 justify-content-center">
                            <input class="form-control" asp-for="@Model.AuthoringProviderSignature"
                                placeholder="Provider Signature"
                                id="providersignature"
                                required/>
                            </div>       
                        </div>
                        <div class="row form-group">
                            <label for="authoringdate" class="col-sm-4 col-form-label">Date Signed: </label>
                            <div class="col-sm-8">
                                <input type="datetime-local"  asp-for="@Model.AuthoringProviderSignedDate" name="AuthoringProviderSignedDate"
                                    class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                                    id="authoringdate"/>
                            </div>
                        </div>
                    </div>
                    <hr/>

                    <div class="col-12 col-lg-6">
                        <div id="cosign" style="display:none">
                            <div class="row mb-3 form-group">
                                <label for="coPhysician" class="col-sm-4 col-form-label">Co-Provider: </label>
                                <div class="col-sm-8 justify-content-center">
                                    <select id="coPhysician" class="form-control dropdowns"
                                        asp-for="@Model.CoPhysicianId" asp-items="coSigner"
                                        name="CoPhysicianId"
                                        >
                                        <option value="">Select a Co-Provider</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3 form-group">
                                <label for="coprovidersignature" class="col-sm-4 col-form-label">Co-Signature:</label>
                                <div class="col-sm-8 justify-content-center">
                                <input class="form-control" asp-for="@Model.CoSigningProviderSignature"
                                    oninput="provideDateTime()"
                                    placeholder="Co-Provider Signature"
                                    id="coprovidersignature"
                                    />
                                </div>       
                            </div>
                            <div class="row mb-3 form-group" id="timeStamp">
                                <label for="coauthoringdate" class="col-sm-4 col-form-label">Date Signed: </label>
                                <div class="col-sm-8">
                                    <input type="text"  asp-for="@Model.CoSigningProviderSignedDate"
                                        name="CoSigningProviderSignedDate"
                                        class="form-control"
                                        value=""
                                        placeholder="Date/Time"
                                        id="coauthoringdate"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                    
                <hr/>
                <button class="btn btn-primary" 
                    onclick="return setFormSubmit()" 
                    type="submit">
                    Create New Progress Note
                </button>
                <button class="btn btn-secondary" formnovalidate
                    asp-controller="Encounter" 
                    asp-action="ProgressNotes"
                    asp-route-id="@Model.Encounter.EncounterId">Cancel
                </button>
            </form>
        </div>
    </div>
</div>


    <script>
        @* Makes the cosign field render based on the 'ProviderStatusId' value in the database *@
        $(function () {
            // Cosign field render based on the 'ProviderStatusId' value in the database
            $('.sign').on('click', function (){

                let providerId= $('.sign').val();
                
                if(providerId != 0)
                {
                    let idNumber = ""

                    $.ajax({
                        type: "GET",
                        url: "@Url.Action("GetProviderStatusId")",
                        dataType: "json",
                        data: {id: providerId},
                        success: function(result){
                            idNumber = result.providerIdNumber
                            if(idNumber == 1)
                            {
                                $('#cosign').hide();
                            }
                            else if(idNumber == 2 || idNumber == 3)
                            {
                                $('#coPhysician').attr("required","required");
                                $('#cosign').show();                     
                            }
                        },
                    });
                } 
            });
            $('#editor').summernote();
        });

        var formSubmit = false;
        var setFormSubmit = function() {
            Validation();
            formSubmit = true;
        };

        window.onload = function() {
            window.addEventListener("beforeunload",
                function(e) {
                    if (formSubmit) {
                        return undefined;
                    }
                    var message = "If you leave before saving, your changes will be lost.";
                    e.returnValue = message;
                });
        };

            function provideDateTime(){
            document.getElementById("timeStamp").innerHTML=
            `
            <label for="coauthoringdate" class="col-sm-4 col-form-label">Date Signed: </label>
                <div class="col-sm-8">
                    <input type="datetime-local"  asp-for="@Model.CoSigningProviderSignedDate"
                        name="CoSigningProviderSignedDate"
                        class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                        id="coauthoringdate"/>
                </div>
            `
        };
    </script>
