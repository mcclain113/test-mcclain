@model List<IS_Proj_HIT.Entities.BloodPressureRouteType>

@{
    ViewData["Title"] = "Blood Pressure Route Types";
    var userPermissions = ViewData["UserPermissions"] as List<string>;
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="PCAStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Blood Pressure Route Types
    </h3>
</div>
<!-- banner displays used when deleting an item  -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }
    
<div>
    @if (userPermissions != null && (userPermissions.Contains("StructuredDataAdd")) )
    {
        <a class="btn btn-primary mb-3" asp-controller="PCAStructuredData" asp-action="CreateBPRouteType">Create New</a>
    }
</div>

<table class="stripe nowrap" id="bpRouteTypeTable">
    <thead>
        <tr>
            <th>Blood Pressure Route Type Name</th>
            <th style="text-align: center;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var bpRouteType in Model)
        {
            <tr>
                <td>@bpRouteType.Name</td>
                <td>
                    @if (userPermissions != null && (userPermissions.Contains("StructuredDataEdit")) )
                    {
                        <a class="btn btn-primary" asp-controller="PCAStructuredData" asp-action="EditBPRouteType" asp-route-id="@bpRouteType.BloodPressureRouteTypeId">Edit</a>
                    }
                    @if (userPermissions != null && (userPermissions.Contains("StructuredDataDelete")) )
                    {
                        <a class="btn btn-danger" onclick="return confirm('Are you sure?')" asp-controller="PCAStructuredData" asp-action="DeleteBPRouteType" asp-route-id="@bpRouteType.BloodPressureRouteTypeId">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // DataTable Documentation found here: https://datatables.net/
        $(document).ready(function () {
            // Creates DataTable
            $('#bpRouteTypeTable').DataTable({
                columns: [null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}