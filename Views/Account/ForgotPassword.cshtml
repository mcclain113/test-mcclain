@model IS_Proj_HIT.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="container">
    <div class="row justify-content-center">
        <h1>@ViewData["Title"]</h1>
    </div>
    <div class="row justify-content-center">
        <div class="col-md-4">
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger"></div>
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
                <div class="form-group">
                    <label asp-for="Email">Email:</label>
                    <input type="email" asp-for="Email" value="@Model.Email" class="form-control" readonly />
                </div>

                @for (int i = 0; i < Model.SecurityQuestionsAndAnswers.Count; i++)
                {
                    <div class="form-group">
                        <label>@Model.SecurityQuestionsAndAnswers[i].QuestionText</label>
                        <input type="hidden" name="SecurityQuestionsAndAnswers[@i].SecurityQuestionId" value="@Model.SecurityQuestionsAndAnswers[i].SecurityQuestionId" />
                        <input type="text"  class="form-control" name="SecurityQuestionsAndAnswers[@i].Answer" required />
                    </div>
                }

                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>
