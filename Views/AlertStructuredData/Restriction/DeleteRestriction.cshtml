@model IS_Proj_HIT.ViewModels.AlertStructuredData.AlertStructuredDataViewModel
@{
    ViewBag.Title = "Delete Restriction";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Restriction</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <input type="hidden" asp-for="Restriction.RestrictionId" value="@Model.Restriction.RestrictionId" readonly/>
                <div class="form-group col-sm-6">
                    <label asp-for="Restriction.Name" class="control-label">Restriction Name</label>
                    <input asp-for="Restriction.Name" class="form-control" disabled />
                </div>
            </div>
            <div class="row">
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

<div>
    <a asp-controller="AlertStructuredData" asp-action="ViewRestrictions">Back to List</a>
</div>