                </div>
            </div>
        </div>
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="AlertStructuredData" asp-action="ViewFallRisks">Fall Risk</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="AlertStructuredData" asp-action="ViewRestrictions">Restricted Access Types</a>
                </div>
            </div>
        </div> 
    </div>
</div>