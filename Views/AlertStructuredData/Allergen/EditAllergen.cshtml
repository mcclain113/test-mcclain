@model IS_Proj_HIT.ViewModels.AlertStructuredData.AlertStructuredDataViewModel
@{
    ViewBag.Title = "Create Allergen";
}

<h1>Edit</h1>

<h4>Allergen</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Allergen.AllergenId" value="@Model.Allergen.AllergenId" readonly/>
                <div class="form-group col-sm-6">
                    <label asp-for="Allergen.AllergenName" class="control-label">Allergen Name</label>
                    <input asp-for="Allergen.AllergenName" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Food - Corn" />
                    <span asp-validation-for="Allergen.AllergenName" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="Allergen.Description" class="control-label">Description</label>
                    <input asp-for="Allergen.Description" 
                        class="form-control"  
                        placeholder="Example:  Food - corn"/>
                    <span asp-validation-for="Allergen.Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Save Changes" class="btn btn-primary" />
                </div>

            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="AlertStructuredData" asp-action="ViewAllergens">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}