@model IS_Proj_HIT.ViewModels.AlertStructuredData.AlertStructuredDataViewModel
@{
    ViewBag.Title = "Delete Allergen";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Allergen</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <input type="hidden" asp-for="Allergen.AllergenId" value="@Model.Allergen.AllergenId" readonly/>
                <div class="form-group col-sm-6">
                    <label asp-for="Allergen.AllergenName" class="control-label">Allergen Name</label>
                    <input asp-for="Allergen.AllergenName" class="form-control" disabled/>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="Allergen.Description" class="control-label">Description</label>
                    <input asp-for="Allergen.Description" class="form-control" disabled />
                </div>
            </div> 
            <div class="row">   
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

<div>
    <a asp-controller="AlertStructuredData" asp-action="ViewAllergens">Back to List</a>
</div>