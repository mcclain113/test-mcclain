@model IS_Proj_HIT.ViewModels.BirthRegistry.FinalizeViewModel

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
            <i class="fas fa-file-signature mr-2"></i> Finalize Birth Record
        </h4>
        <span class="badge badge-light text-dark">View Mode</span>
    </div>

    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(Model.RegistrarSignature))
        {
            <div class="alert alert-success" role="alert">
                <div class="d-flex align-items-center">
                    <i class="fas fa-check-circle fa-2x mr-3"></i>
                    <div>
                        <h5 class="alert-heading mb-1">Record Finalized</h5>
                        <p class="mb-0">This birth record has been finalized and marked as complete.</p>
                    </div>
                </div>
            </div>

            <dl class="row">
                <dt class="col-md-4">Registrar Signature</dt>
                <dd class="col-md-8">
                    <span class="signature-display">@Model.RegistrarSignature</span>
                </dd>

                <dt class="col-md-4">Date of Signature</dt>
                <dd class="col-md-8">
                    @if (Model.DateOfRegistrarSignature.HasValue)
                    {
                        @Model.DateOfRegistrarSignature.Value.ToString("MMMM dd, yyyy")
                    }
                    else
                    {
                        <span class="text-muted">Not recorded</span>
                    }
                </dd>
            </dl>
        }
        else
        {
            <div class="alert alert-warning" role="alert">
                <i class="fas fa-exclamation-triangle mr-2"></i>
                <strong>Not Yet Finalized</strong>
                <p class="mb-0 mt-2">This birth record has not been finalized. The registrar signature is required to complete the record.</p>
            </div>

            <dl class="row">
                <dt class="col-md-4">Registrar Signature</dt>
                <dd class="col-md-8">
                    <span class="text-muted">Pending</span>
                </dd>

                <dt class="col-md-4">Date of Signature</dt>
                <dd class="col-md-8">
                    <span class="text-muted">Pending</span>
                </dd>
            </dl>
        }
    </div>
</div>

<style>
    .signature-display {
        font-family: 'Brush Script MT', cursive, 'Dancing Script', 'Sacramento', serif;
        font-size: 2rem;
        font-style: italic;
        color: #000080;
        font-weight: 500;
        display: inline-block;
        line-height: 1.3;
    }
</style>