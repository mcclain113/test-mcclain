@model IS_Proj_HIT.ViewModels.BirthRegistry.FatherInformationViewModel

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
            <i class="fas fa-male mr-2"></i>Father's Information
        </h4>
        <span class="badge badge-light text-dark">View Mode</span>
    </div>
    <div class="card-body">
        <div id="fatherInformationDisplay">
            <div id="fatherAccordion">

                <div class="card">
                    <div class="card-header bg-primary text-white" id="headingPaternity">
                        <h5 class="mb-0">
                            <button class="btn btn-block text-left text-white" type="button" 
                                    data-toggle="collapse" data-target="#collapsePaternity" 
                                    aria-expanded="true" aria-controls="collapsePaternity">
                                <i class="fas fa-exclamation-triangle mr-1"></i>1. Paternity Acknowledgement
                            </button>
                        </h5>
                    </div>
                    <div id="collapsePaternity" class="collapse show" aria-labelledby="headingPaternity" data-parent="#fatherAccordion">
                        <div class="card-body">
                            <div class="form-group">
                                <label class="form-label font-weight-bold">
                                    Paternity Acknowledgement Completed
                                    <i class="fas fa-info-circle text-info ml-2" 
                                       data-toggle="tooltip" 
                                       data-placement="top" 
                                       data-html="true"
                                       title="Father information is included on the birth certificate only when paternity acknowledgement is completed."></i>
                                </label>
                                
                                <div class="border p-3 bg-light">
                                    @if (Model.HasPaternityAcknowledgement == true)
                                    {
                                        <div class="text-success">
                                            <i class="fas fa-check-circle mr-2"></i>
                                            <strong>Yes</strong> - Father information will be included on the birth certificate.
                                        </div>
                                    }
                                    else if (Model.HasPaternityAcknowledgement == false)
                                    {
                                        <div class="text-warning">
                                            <i class="fas fa-times-circle mr-2"></i>
                                            <strong>No</strong> - Father information will not be included on the birth certificate.
                                            <br>
                                            <small class="text-muted">Information below is for record-keeping purposes only.</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted">
                                            <i class="fas fa-question-circle mr-2"></i>
                                            <strong>Not specified</strong>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-primary text-white" id="headingFatherName">
                        <h5 class="mb-0">
                            <button class="btn btn-block text-left text-white collapsed" type="button" 
                                    data-toggle="collapse" data-target="#collapseFatherName" 
                                    aria-expanded="false" aria-controls="collapseFatherName">
                                <i class="fas fa-user mr-1"></i>2. Father's Current Legal Name
                            </button>
                        </h5>
                    </div>
                    <div id="collapseFatherName" class="collapse show" aria-labelledby="headingFatherName" data-parent="#fatherAccordion">
                        <div class="card-body">
                            @if (Model.HasPaternityAcknowledgement == false)
                            {
                                <div class="alert alert-warning mb-3">
                                    <i class="fas fa-exclamation-triangle mr-2"></i>
                                    <strong>Note:</strong> This information is for internal records only and will not appear on the birth certificate.
                                </div>
                            }
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="control-label font-weight-bold">First Name</label>
                                        <div class="form-control-plaintext border p-2 bg-light">
                                            @(Model.FirstName ?? "Not provided")
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="control-label font-weight-bold">Middle Name</label>
                                        <div class="form-control-plaintext border p-2 bg-light">
                                            @(Model.MiddleName ?? "Not provided")
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="control-label font-weight-bold">Last Name</label>
                                        <div class="form-control-plaintext border p-2 bg-light">
                                            @(Model.LastName ?? "Not provided")
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="control-label font-weight-bold">Suffix</label>
                                        <div class="form-control-plaintext border p-2 bg-light">
                                            @(Model.Suffix ?? "Not provided")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-primary text-white" id="headingFatherPersonal">
                        <h5 class="mb-0">
                            <button class="btn btn-block text-left text-white collapsed" type="button" 
                                    data-toggle="collapse" data-target="#collapseFatherPersonal" 
                                    aria-expanded="false" aria-controls="collapseFatherPersonal">
                                <i class="fas fa-id-card mr-1"></i>3. Father's Personal Information
                            </button>
                        </h5>
                    </div>
                    <div id="collapseFatherPersonal" class="collapse show" aria-labelledby="headingFatherPersonal" data-parent="#fatherAccordion">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="control-label font-weight-bold">Date of Birth</label>
                                        <div class="form-control-plaintext border p-2 bg-light">
                                            @(Model.DateOfBirth?.ToString("MM/dd/yyyy") ?? "Not provided")
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="control-label font-weight-bold">Birth Place</label>
                                        <div class="form-control-plaintext border p-2 bg-light">
                                            @(Model.FatherBirthplace ?? "Not provided")
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="control-label font-weight-bold">Social Security Number</label>
                                        <div class="form-control-plaintext border p-2 bg-light">
                                            @(Model.SSN ?? "Not provided")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-primary text-white" id="headingFatherDemographic">
                        <h5 class="mb-0">
                            <button class="btn btn-block text-left text-white collapsed" type="button" 
                                    data-toggle="collapse" data-target="#collapseFatherDemographic" 
                                    aria-expanded="false" aria-controls="collapseFatherDemographic">
                                <i class="fas fa-globe mr-1"></i>4. Father's Demographic Information
                            </button>
                        </h5>
                    </div>
                    <div id="collapseFatherDemographic" class="collapse show" aria-labelledby="headingFatherDemographic" data-parent="#fatherAccordion">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-12">
                                    <div class="form-group">
                                        <label class="control-label font-weight-bold">Education Level</label>
                                        <div class="form-control-plaintext border p-2 bg-light">
                                            @(Model.EducationLevel?.EducationLevelName ?? "Not specified")
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-group">
                                        <label class="control-label font-weight-bold">Ethnicity</label>
                                        <div class="form-control-plaintext border p-2 bg-light">
                                            @(Model.Ethnicity?.Name ?? "Not specified")
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="control-label font-weight-bold">Race</label>
                                <div class="border p-2 bg-light">
                                    @if (Model.SelectedRaceIds != null && Model.SelectedRaceIds.Any())
                                    {
                                        @foreach (var raceId in Model.SelectedRaceIds)
                                        {
                                            var race = Model.Races?.FirstOrDefault(r => r.Value == raceId.ToString());
                                            if (race != null)
                                            {
                                                <span class="badge badge-primary mr-1 mb-1">@race.Text</span>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not specified</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>