@model IS_Proj_HIT.ViewModels.BirthRegistry.FatherInformationViewModel

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
            <i class="fas fa-male mr-2"></i>Father's Information
        </h4>
        @if (ViewBag.Mode == "edit")
        {
            <span class="badge badge-warning text-white">Edit Mode</span>
        }
    </div>
    <div class="card-body">
        <div id="fatherAccordion">

            <!-- Paternity Acknowledgement Section -->
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center" id="headingPaternity">
                    <h5 class="mb-0">
                        <button class="btn btn-block text-left text-white @(ViewBag.Mode == "edit" ? "no-collapse" : "")" type="button" 
                                data-toggle="collapse" data-target="#collapsePaternity" 
                                aria-expanded="true" aria-controls="collapsePaternity">
                            <i class="fas fa-exclamation-triangle mr-1"></i>1. Paternity Acknowledgement
                        </button>
                    </h5>
                    <span class="checkmark accordion-checkmark">&#10004;</span>
                </div>
                <div id="collapsePaternity" class="collapse show" aria-labelledby="headingPaternity" data-parent="@(ViewBag.Mode == "edit" ? "" : "#fatherAccordion")">
                    <div class="card-body">
                        <input type="hidden" asp-for="BirthFatherId" />
                        
                        <div class="form-group">
                            <label class="form-label font-weight-bold">
                                Has a paternity acknowledgement been completed?
                                <i class="fas fa-info-circle text-info ml-2" 
                                   data-toggle="tooltip" 
                                   data-placement="top" 
                                   data-html="true"
                                   title="<strong>Important:</strong> Father information is collected to create the birth certificate of the newborn.<br><br>If paternity acknowledgment is not completed, father information cannot be included on the birth certificate."></i>
                            </label>
                            
                            <div class="form-check">
                                <input class="form-check-input validation-trigger" 
                                       type="radio" 
                                       name="Father.HasPaternityAcknowledgement" 
                                       id="paternityYes" 
                                       value="True" 
                                       data-validation-group="fatherPaternity"
                                       data-special-trigger="paternity"
                                       @(Model.HasPaternityAcknowledgement == true ? "checked" : "") />
                                <label class="form-check-label" for="paternityYes">Yes</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input validation-trigger" 
                                       type="radio" 
                                       name="Father.HasPaternityAcknowledgement" 
                                       id="paternityNo" 
                                       value="False" 
                                       data-validation-group="fatherPaternity"
                                       data-special-trigger="paternity"
                                       @(Model.HasPaternityAcknowledgement == false ? "checked" : "") />
                                <label class="form-check-label" for="paternityNo">No</label>
                            </div>
                            
                            <div id="paternityStatusMessage" class="mt-2" style="display: none;">
                                <div id="paternityYesMessage" class="text-success small" style="display: none;">
                                    <i class="fas fa-check-circle mr-1"></i>
                                    Father information will be included on the birth certificate.
                                </div>
                                <div id="paternityNoMessage" class="text-muted small" style="display: none;">
                                    <i class="fas fa-info-circle mr-1"></i>
                                    Father information will not be included on the birth certificate.
                                </div>
                            </div>
                        </div>

                        @if (ViewBag.Mode != "edit")
                        {
                            <div class="next-button-container text-right">
                                <button type="button" class="btn btn-primary next-accordion-btn" data-target-collapse="#collapseFatherName" disabled>
                                    Next <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Father's Current Legal Name Section -->
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center" id="headingFatherName">
                    <h5 class="mb-0">
                        <button class="btn btn-block text-left text-white @(ViewBag.Mode == "edit" ? "no-collapse" : "collapsed")" type="button" 
                                data-toggle="collapse" data-target="#collapseFatherName" 
                                aria-expanded="@(ViewBag.Mode == "edit" ? "true" : "false")" aria-controls="collapseFatherName">
                            <i class="fas fa-user mr-1"></i>2. Father's Current Legal Name
                        </button>
                    </h5>
                    <span class="checkmark accordion-checkmark">&#10004;</span>
                </div>
                <div id="collapseFatherName" class="collapse @(ViewBag.Mode == "edit" ? "show" : "")" aria-labelledby="headingFatherName" data-parent="@(ViewBag.Mode == "edit" ? "" : "#fatherAccordion")">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="FirstName" class="control-label">First Name *</label>
                                    <input asp-for="FirstName" 
                                           name="Father.FirstName" 
                                           class="form-control validation-trigger"
                                           data-validation-group="fatherName" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="MiddleName" class="control-label">Middle Name</label>
                                    <input asp-for="MiddleName" name="Father.MiddleName" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="LastName" class="control-label">Last Name *</label>
                                    <input asp-for="LastName" 
                                           name="Father.LastName" 
                                           class="form-control validation-trigger"
                                           data-validation-group="fatherName" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="Suffix" class="control-label">Suffix</label>
                                    <input asp-for="Suffix" name="Father.Suffix" class="form-control" placeholder="Jr., Sr., III, etc." />
                                </div>
                            </div>
                        </div>

                        @if (ViewBag.Mode != "edit")
                        {
                            <div class="next-button-container text-right">
                                <button type="button" class="btn btn-primary next-accordion-btn" data-target-collapse="#collapseFatherPersonal" disabled>
                                    Next <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Father's Personal Information Section -->
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center" id="headingFatherPersonal">
                    <h5 class="mb-0">
                        <button class="btn btn-block text-left text-white @(ViewBag.Mode == "edit" ? "no-collapse" : "collapsed")" type="button" 
                                data-toggle="collapse" data-target="#collapseFatherPersonal" 
                                aria-expanded="@(ViewBag.Mode == "edit" ? "true" : "false")" aria-controls="collapseFatherPersonal">
                            <i class="fas fa-id-card mr-1"></i>3. Father's Personal Information
                        </button>
                    </h5>
                    <span class="checkmark accordion-checkmark">&#10004;</span>
                </div>
                <div id="collapseFatherPersonal" class="collapse @(ViewBag.Mode == "edit" ? "show" : "")" aria-labelledby="headingFatherPersonal" data-parent="@(ViewBag.Mode == "edit" ? "" : "#fatherAccordion")">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="DateOfBirth" class="control-label">Date of Birth</label>
                                    <input asp-for="DateOfBirth" 
                                           name="Father.DateOfBirth" 
                                           class="form-control validation-trigger" 
                                           type="date"
                                           data-validation-group="fatherPersonal" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="FatherBirthplace" class="control-label">Birth Place</label>
                                    <input asp-for="FatherBirthplace" name="Father.FatherBirthplace" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="SSN" class="control-label">Social Security Number</label>
                                    <input asp-for="SSN" name="Father.SSN" class="form-control" pattern="[0-9]{3}-?[0-9]{2}-?[0-9]{4}" />
                                </div>
                            </div>
                        </div>

                        @if (ViewBag.Mode != "edit")
                        {
                            <div class="next-button-container text-right">
                                <button type="button" class="btn btn-primary next-accordion-btn" data-target-collapse="#collapseFatherDemographic" disabled>
                                    Next <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Father's Demographic Information Section -->
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center" id="headingFatherDemographic">
                    <h5 class="mb-0">
                        <button class="btn btn-block text-left text-white @(ViewBag.Mode == "edit" ? "no-collapse" : "collapsed")" type="button" 
                                data-toggle="collapse" data-target="#collapseFatherDemographic" 
                                aria-expanded="@(ViewBag.Mode == "edit" ? "true" : "false")" aria-controls="collapseFatherDemographic">
                            <i class="fas fa-globe mr-1"></i>4. Father's Demographic Information <small class="text-muted">(Optional)</small>
                        </button>
                    </h5>
                    <span class="checkmark accordion-checkmark">&#10004;</span>
                </div>
                <div id="collapseFatherDemographic" class="collapse @(ViewBag.Mode == "edit" ? "show" : "")" aria-labelledby="headingFatherDemographic" data-parent="@(ViewBag.Mode == "edit" ? "" : "#fatherAccordion")">
                    <div class="card-body">
                        <div class="card border-left-warning mb-3">
                            <div class="card-body py-2">
                                <div class="form-check">
                                    <input type="checkbox" 
                                           class="form-check-input validation-trigger" 
                                           id="skipFatherDemo" 
                                           data-validation-group="fatherDemo"
                                           data-special-trigger="skipDemo">
                                    <label class="form-check-label" for="skipFatherDemo">
                                        <i class="fas fa-forward"></i> 
                                        <strong>Skip demographic information</strong> 
                                        <small class="text-muted">(information not available or prefer not to provide)</small>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <p class="text-muted mb-3">
                            <i class="fas fa-info-circle"></i> 
                            All demographic information is optional. Fill in any available information or skip this section entirely.
                        </p>
                        
                        <div class="row">
                            <div class="col-12">
                                <div class="form-group">
                                    <label asp-for="EducationLevel" class="control-label">Education Level</label>
                                    <select asp-for="EducationLevel.EducationId" 
                                            name="Father.EducationLevel.EducationId" 
                                            asp-items="Model.EducationLevels" 
                                            class="form-control validation-trigger"
                                            data-validation-group="fatherDemo">
                                        <option value="">-- Not Specified --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-group">
                                    <label asp-for="Ethnicity" class="control-label">Ethnicity</label>
                                    <select asp-for="Ethnicity.EthnicityId" 
                                            name="Father.Ethnicity.EthnicityId" 
                                            asp-items="Model.Ethnicities" 
                                            class="form-control validation-trigger"
                                            data-validation-group="fatherDemo">
                                        <option value="">-- Not Specified --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-group">
                                    <label class="control-label">Race <small class="text-muted">(Select all that apply)</small></label>
                                    <div class="checkbox-group">
                                        @if (Model.Races?.Any() == true)
                                        {
                                            @foreach (var race in Model.Races)
                                            {
                                                <div class="form-check">
                                                    <input type="checkbox" 
                                                           class="form-check-input father-race validation-trigger" 
                                                           name="Father.SelectedRaceIds" 
                                                           value="@race.Value"
                                                           id="father-race-@race.Value"
                                                           data-validation-group="fatherDemo"
                                                           @(Model.SelectedRaceIds.Contains(byte.Parse(race.Value)) ? "checked" : "") />
                                                    <label class="form-check-label" for="father-race-@race.Value">
                                                        @race.Text
                                                    </label>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="next-button-container text-right">
                            @if (ViewBag.Mode == "edit")
                            {
                                <button type="button" class="btn btn-success btn-lg save-tab-btn">
                                    <i class="fas fa-save"></i> Save Father Information
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-primary next-tab-btn" disabled>
                                    Next: Prenatal Care <i class="fas fa-arrow-right"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
