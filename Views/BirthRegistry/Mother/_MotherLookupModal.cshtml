@* Views/BirthRegistry/Mother/_MotherLookupModal.cshtml *@

<div class="modal fade center-viewport" id="motherLookupModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" role="document" style="max-width:560px;">
    <div class="modal-content">

      <div class="modal-header bg-primary text-white">
        <h3 class="modal-title" id="motherLookupModalLabel">Mother Lookup</h3>
        <button type="button" class="close text-white" data-dismiss="modal">
          <span>&times;</span>
        </button>
      </div>

      <div class="modal-body bg-light">
        <input type="text" class="form-control mb-2" id="searchFirst" placeholder="First Name" />
        <input type="text" class="form-control mb-3" id="searchLast" placeholder="Last Name" />

        <input type="text" class="form-control mb-2" id="searchMRN" placeholder="MRN" />
        <input type="text" class="form-control mb-3" id="searchSSN" placeholder="SSN" />

        <input type="date" class="form-control mb-2" id="searchDOB" placeholder="Date of Birth After This" />
        <input type="date" class="form-control mb-3" id="searchDOBBefore" placeholder="Date of Birth Before This" />

        <!-- results get injected here -->
        <div class="mt-3 d-none" id="motherLookupResultsWrap">
          <div id="motherLookupResultsHost"></div>
        </div>
      </div>

      <div class="modal-footer bg-light d-block">
        <button type="button" class="btn btn-dark btn-lg btn-block" id="motherLookupSearchBtn">
          <i class="fas fa-search"></i> Search
        </button>
      </div>

    </div>
  </div>
</div>