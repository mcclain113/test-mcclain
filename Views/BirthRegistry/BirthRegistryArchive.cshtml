@model List<IS_Proj_HIT.ViewModels.BirthRegistry.BirthRegistryArchiveViewModel>
@using Microsoft.AspNetCore.Routing
@{
    ViewData["Title"] = "Birth Registry";
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 25);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var sortBy = ViewBag.SortBy as string ?? "motherLastName";
    var sortOrder = ViewBag.SortOrder as string ?? "asc";
    var hasSearchCriteria = (bool)(ViewBag.HasSearchCriteria ?? false);
    var searchParams = ViewBag.SearchParams as Dictionary<string, object> ?? new Dictionary<string, object>();

    string GetSortUrl(string column)
    {
        var newOrder = (sortBy == column && sortOrder == "asc") ? "desc" : "asc";
        var routeValues = new RouteValueDictionary(searchParams)
        {
            ["sortBy"] = column,
            ["sortOrder"] = newOrder,
            ["page"] = 1
        };
        return Url.Action("BirthRegistryArchive", routeValues);
    }

    string GetSortIcon(string column)
    {
        if (sortBy != column) return "fas fa-sort text-muted";
        return sortOrder == "asc" ? "fas fa-sort-up" : "fas fa-sort-down";
    }

    string GetPaginationUrl(int page)
    {
        var routeValues = new RouteValueDictionary(searchParams)
        {
            ["page"] = page
        };
        return Url.Action("BirthRegistryArchive", routeValues);
    }
}

<div class="container-fluid mt-2">
    @Html.AntiForgeryToken()
    <div class="modal fade" id="deleteBirthRegistry" tabindex="-1" role="dialog" aria-labelledby="deleteBirthRegistryTitle" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteBirthRegistryTitle">
                        <i class="fas fa-exclamation-triangle mr-2"></i>Confirm Deletion
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p class="message"></p>
                    <div class="alert alert-warning">
                        <strong>Warning:</strong> This action cannot be undone.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-nav" data-dismiss="modal"> Cancel
                    </button>
                    <button type="button" class="btn btn-danger delete-confirm" data-dismiss="modal"> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="fas fa-archive mr-2"></i>Birth Registry
                        @if (hasSearchCriteria)
                        {
                            <small class="ml-2">(Filtered Results)</small>
                        }
                    </h4>
                    <div>
                        <a asp-action="Create" class="btn btn-light">
                            <i class="fas fa-plus"></i> New Registry
                        </a>
                        <a asp-action="BirthRegistrySearch" class="btn btn-light">
                            <i class="fas fa-search"></i> Search
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div>
                            <i class="fas fa-check-circle mr-2"></i>@TempData["SuccessMessage"]
                            <button type="button" class="close" data-dismiss="alert">&times;</button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="fas fa-exclamation-circle mr-2"></i>@TempData["ErrorMessage"]
                            <button type="button" class="close" data-dismiss="alert">&times;</button>
                        </div>
                    }

                    @if (Model != null && Model.Any())
                    {
                        <div>
                            <div class="d-flex align-items-center">
                                <label for="pageSize" class="mr-2 mb-0">Per page:</label>
                                <select id="pageSize" class="form-control form-control-sm" style="width: 80px;" onchange="changePageSize(this.value)">
                                    @foreach (var option in new[] { 10, 25, 50, 100 })
                                    {
                                    <option value="@option" selected="@(option == pageSize)">@option</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <i class="fas fa-info-circle mr-2"></i>
                                Found <strong>@totalCount</strong> total record(s), showing <strong>@Model.Count</strong> on this page
                                <span class="ml-2">
                                    | <span class="badge badge-success">@Model.Count(r => r.IsComplete) complete</span>
                                    <span class="badge badge-warning">@Model.Count(r => !r.IsComplete) incomplete</span>
                                </span>
                            </div>

                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>
                                            <a href="@GetSortUrl("motherLastName")" class="text-white text-decoration-none">
                                                Mother <i class="@GetSortIcon("motherLastName")"></i>
                                            </a>
                                        </th>
                                        <th>
                                            <a href="@GetSortUrl("newbornname")" class="text-white text-decoration-none">
                                                Newborn <i class="@GetSortIcon("newbornname")"></i>
                                            </a>
                                        </th>
                                        <th>
                                            <a href="@GetSortUrl("facility")" class="text-white text-decoration-none">
                                                Facility <i class="@GetSortIcon("facility")"></i>
                                            </a>
                                        </th>
                                        <th>
                                            <a href="@GetSortUrl("certifier")" class="text-white text-decoration-none">
                                                Certifier <i class="@GetSortIcon("certifier")"></i>
                                            </a>
                                        </th>
                                        <th>
                                            <a href="@GetSortUrl("status")" class="text-white text-decoration-none">
                                                Status <i class="@GetSortIcon("status")"></i>
                                            </a>
                                        </th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@item.MotherName</strong><br />
                                                <small class="text-muted">MRN: @item.MotherMrn</small><br />
                                                <small class="text-muted">DOB: @(item.MotherDob?.ToString("MM/dd/yyyy") ?? "N/A")</small>
                                                @if (item.BirthCount > 1)
                                                {
                                                    <br />
                                                    <span class="badge badge-info mt-1">
                                                        <i class="fas fa-baby"></i> @item.BirthCount Births
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.NewbornName != "Not Assigned")
                                                {
                                                    <strong>@item.NewbornName</strong><br />
                                                    <small class="text-muted">MRN: @item.NewbornMrn</small><br />
                                                    <small class="text-muted">DOB: @(item.NewbornDob?.ToString("MM/dd/yyyy") ?? "N/A")</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">@item.NewbornName</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.FacilityName))
                                                {
                                                    <small>@item.FacilityName</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.CertifierSignature))
                                                {
                                                    <small>@item.CertifierSignature</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Not signed</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.IsComplete)
                                                {
                                                    <span class="badge badge-success">
                                                        <i class="fas fa-check"></i> Complete
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-warning">
                                                        <i class="fas fa-exclamation"></i> Incomplete
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group-vertical btn-group-sm w-100" role="group">
                                                    <a asp-action="ViewBirthRegistry" asp-route-id="@item.BirthId" 
                                                       class="btn btn-nav me-2">View
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@item.BirthId"
                                                       class="btn btn-info text-white">Edit
                                                    </a>
                                                    <button data-birth-id="@item.BirthId" 
                                                            data-newborn-name="@item.NewbornName" 
                                                            data-mother-name="@item.MotherName"
                                                            type="button" 
                                                            class="btn btn-danger" 
                                                            data-toggle="modal" 
                                                            data-target="#deleteBirthRegistry">Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (totalPages > 1)
                        {
                            <nav aria-label="Archive pagination">
                                <ul class="pagination justify-content-center">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" href="@GetPaginationUrl(1)">
                                            <i class="fas fa-angle-double-left"></i> First
                                        </a>
                                    </li>
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" href="@GetPaginationUrl(currentPage - 1)">
                                            <i class="fas fa-angle-left"></i> Previous
                                        </a>
                                    </li>

                                    @{
                                        var startPage = Math.Max(1, currentPage - 2);
                                        var endPage = Math.Min(totalPages, currentPage + 2);
                                    }

                                    @if (startPage > 1)
                                    {
                                        <li class="page-item"><span class="page-link">...</span></li>
                                    }

                                    @for (int i = startPage; i <= endPage; i++)
                                    {
                                        <li class="page-item @(i == currentPage ? "active" : "")">
                                            <a class="page-link" href="@GetPaginationUrl(i)">@i</a>
                                        </li>
                                    }

                                    @if (endPage < totalPages)
                                    {
                                        <li class="page-item"><span class="page-link">...</span></li>
                                    }

                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <a class="page-link" href="@GetPaginationUrl(currentPage + 1)">
                                            Next <i class="fas fa-angle-right"></i>
                                        </a>
                                    </li>
                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <a class="page-link" href="@GetPaginationUrl(totalPages)">
                                            Last <i class="fas fa-angle-double-right"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>

                            <div class="text-center text-muted">
                                Showing @((currentPage - 1) * pageSize + 1) to @(Math.Min(currentPage * pageSize, totalCount)) of @totalCount
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <h5><i class="fas fa-info-circle"></i> No Records Found</h5>
                            @if (hasSearchCriteria)
                            {
                                <p>No records match your search criteria.</p>
                                <button type="button" class="btn btn-primary" onclick="clearSearch()">
                                    <i class="fas fa-undo"></i> Clear Filters
                                </button>
                            }
                            else
                            {
                                <p>The birth registry archive is empty.</p>
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-plus"></i> Create First Registry
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.open-DeleteBirthRegistry', function() {
            const newbornName = $(this).data('newborn-name');
            const motherName = $(this).data('mother-name');
            const birthId = $(this).data('birth-id');

            $('.modal-footer .delete-confirm').off('click').on('click', function() {
                const form = $('<form>', {
                    'method': 'POST',
                    'action': `/BirthRegistry/DeleteBirthRegistry/${birthId}`
                });

                const token = $('input[name="__RequestVerificationToken"]').val();
                form.append($('<input>', {
                    'type': 'hidden',
                    'name': '__RequestVerificationToken',
                    'value': token
                }));

                $('body').append(form);
                form.submit();
            });

            $('.modal-body .message').html(
                `Are you sure you want to delete the birth registry for <strong>${newbornName}</strong> (mother: <strong>${motherName}</strong>)?`
            );
        });

        function changePageSize(newPageSize) {
            const url = new URL(window.location.href);
            url.searchParams.set('pageSize', newPageSize);
            url.searchParams.set('page', '1');
            window.location.href = url.toString();
        }

        function clearSearch() {
            window.location.href = '@Url.Action("BirthRegistryArchive")';
        }
    </script>
}