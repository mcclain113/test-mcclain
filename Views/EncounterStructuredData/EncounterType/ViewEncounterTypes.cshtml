@model List<IS_Proj_HIT.Entities.EncounterType>

@{
    ViewData["Title"] = "Encounter Types";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Encounter Types
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="CreateEncounterType">Create New</a>
</p>

<table class="stripe" id="encounterTypeTable">
    <thead>
        <tr>
            <th>
                Encounter Type Name
            </th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var encounterType in Model)
        {
            <tr>
                <td>
                    @encounterType.Name
                </td>
                
                <td class="nowrap-text">
                   
                    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="EditEncounterType" asp-route-id="@encounterType.EncounterTypeId">Edit</a>
                    <a class="btn btn-danger" asp-controller="EncounterStructuredData" asp-action="DeleteEncounterType" asp-route-id="@encounterType.EncounterTypeId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#encounterTypeTable').DataTable({
                columns: [ 
                    null, 
                    { orderable: false},
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}