@model IS_Proj_HIT.ViewModels.EncounterStructuredDataViewModel
@{
    ViewBag.Title = "Create Encounter Type";
}

<h1>Create</h1>

<h4>Encounter Type</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group col-sm-2">
                    <label asp-for="EncounterType.Name" class="control-label">Name</label>
                    <input asp-for="EncounterType.Name" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Inpatient" />
                    <span asp-validation-for="EncounterType.Name" class="text-danger"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="EncounterStructuredData" asp-action="ViewEncounterTypes">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}