@{
    ViewBag.Title = "Encounter Data Entry";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="Administration" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Encounter Data Entry Management
</h3>
</div>

<div class="container">
    <div class="row">
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="EncounterStructuredData" asp-action="ViewAdmitTypes">Admit Type</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="EncounterStructuredData" asp-action="ViewDepartments">Departments</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="EncounterStructuredData" asp-action="ViewDischarges">Discharge</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="EncounterStructuredData" asp-action="ViewEncounterTypes">Encounter Type</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="EncounterStructuredData" asp-action="ViewPlaceOfServiceOutPatients">Place of Service Out Patient</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="EncounterStructuredData" asp-action="ViewPointOfOrigins">Point of Origin</a>
                </div>
            </div>
        </div>

    </div>
</div> 