@model List<IS_Proj_HIT.Entities.AdmitType>

@{
    ViewData["Title"] = "Encounter Admit Types";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Encounter Admit Types
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="CreateAdmitType">Create New</a>
</p>

<table class="stripe" id="admitTypeTable">
    <thead>
        <tr>
            <th>
                WiPopCode
            </th>
            <th>
                Description
            </th>
            <th>
                Explanation
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var admitType in Model)
        {
            <tr>
                <td>
                    @admitType.WiPopCode
                </td>
                <td>
                    @admitType.Description
                </td>
                <td>
                    @admitType.Explaination
                </td>
                <td class="nowrap-text">
                   
                    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="EditAdmitType" asp-route-id="@admitType.AdmitTypeId">Edit</a>
                    <a class="btn btn-danger" asp-controller="EncounterStructuredData" asp-action="DeleteAdmitType" asp-route-id="@admitType.AdmitTypeId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    .wrap-text {
        white-space: normal;
        word-wrap: break-word;
    }
    .nowrap-text {
        white-space: nowrap;
    }
    /* Ensure buttons don't wrap */
    .nowrap-text button {
        white-space: nowrap;
    }
</style>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#admitTypeTable').DataTable({
                columns: [ 
                    null, 
                    null, 
                    { className: 'wrap-text' }, // Apply the wrap-text class to the third column
                    { orderable: false}
                    ],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}