@model List<IS_Proj_HIT.Entities.PointOfOrigin>

@{
    ViewData["Title"] = "Point Of Origin";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Point Of Origins
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="CreatePointOfOrigin">Create New</a>
</p>

<table class="stripe" id="pointOfOriginTable">
    <thead>
        <tr>
            <th>
                WiPopCode
            </th>
            <th>
                Description
            </th>
            <th>
                Explanation
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var pointOfOrigin in Model)
        {
            <tr>
                <td>
                    @pointOfOrigin.WiPopCode
                </td>
                <td>
                    @pointOfOrigin.Description
                </td>
                <td>
                    @pointOfOrigin.Explaination
                </td>
                <td class="nowrap-text">
                   
                    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="EditPointOfOrigin" asp-route-id="@pointOfOrigin.PointOfOriginId">Edit</a>
                    <a class="btn btn-danger" asp-controller="EncounterStructuredData" asp-action="DeletePointOfOrigin" asp-route-id="@pointOfOrigin.PointOfOriginId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    .wrap-text {
        white-space: normal;
        word-wrap: break-word;
    }
    .nowrap-text {
        white-space: nowrap;
    }
    /* Ensure buttons don't wrap */
    .nowrap-text button {
        white-space: nowrap;
    }
</style>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#pointOfOriginTable').DataTable({
                columns: [null, null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}