@model IS_Proj_HIT.ViewModels.EncounterStructuredDataViewModel
@{
    ViewBag.Title = "Edit Place Of Service OutPatient";
}

<h1>Edit</h1>

<h4>Place Of Service OutPatient</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="PlaceOfServiceOutPatient.PlaceOfServiceId" value="@Model.PlaceOfServiceOutPatient.PlaceOfServiceId" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="PlaceOfServiceOutPatient.WiPopCode" class="control-label">WiPopCode</label>
                    <input asp-for="PlaceOfServiceOutPatient.WiPopCode" class="form-control" maxlength="2" required />
                    <span asp-validation-for="PlaceOfServiceOutPatient.WiPopCode" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="PlaceOfServiceOutPatient.Description" class="control-label">Description</label>
                    <input asp-for="PlaceOfServiceOutPatient.Description" class="form-control" maxlength="70" />
                    <span asp-validation-for="PlaceOfServiceOutPatient.Description" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <a asp-controller="EncounterStructuredData" asp-action="ViewPlaceOfServiceOutPatients" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Save Changes" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}