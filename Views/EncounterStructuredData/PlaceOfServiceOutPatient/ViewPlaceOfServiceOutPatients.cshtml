@model List<IS_Proj_HIT.Entities.PlaceOfServiceOutPatient>

@{
    ViewData["Title"] = "Place Of Service OutPatient";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Place Of Service OutPatient
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="CreatePlaceOfServiceOutPatient">Create New</a>
</p>

<table class="stripe nowrap" id="placeOfServiceOutPatientTable">
    <thead>
        <tr>
            <th>
                WiPopCode
            </th>
            <th>
                Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var placeOfServiceOutPatient in Model)
        {
            <tr>
                <td>
                    @placeOfServiceOutPatient.WiPopCode
                </td>
                <td>
                    @placeOfServiceOutPatient.Description
                </td>
                <td>
                   
                    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="EditPlaceOfServiceOutPatient" asp-route-id="@placeOfServiceOutPatient.PlaceOfServiceId">Edit</a>
                    <a class="btn btn-danger" asp-controller="EncounterStructuredData" asp-action="DeletePlaceOfServiceOutPatient" asp-route-id="@placeOfServiceOutPatient.PlaceOfServiceId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#placeOfServiceOutPatientTable').DataTable({
                columns: [null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}