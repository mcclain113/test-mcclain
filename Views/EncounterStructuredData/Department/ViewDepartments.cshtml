@model List<IS_Proj_HIT.Entities.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Departments
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="CreateDepartment">Create New</a>
</p>

<table class="stripe nowrap" id="departmentTable">
    <thead>
        <tr>
            <th>
                Department Name
            </th>
            <th>
                Department Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var department in Model)
        {
            <tr>
                <td>
                    @department.Name
                </td>
                <td>
                    @department.Description
                </td>
                <td>
                   
                    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="EditDepartment" asp-route-id="@department.DepartmentId">Edit</a>
                    <a class="btn btn-danger" asp-controller="EncounterStructuredData" asp-action="DeleteDepartment" asp-route-id="@department.DepartmentId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#departmentTable').DataTable({
                columns: [null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No departments found'
                }
            });
        });
    </script>
}