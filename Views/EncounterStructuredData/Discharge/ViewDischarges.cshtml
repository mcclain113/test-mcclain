@model List<IS_Proj_HIT.Entities.Discharge>

@{
    ViewData["Title"] = "Discharges";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Discharges
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="CreateDischarge">Create New</a>
</p>

<table class="stripe" id="dischargeTable">
    <thead>
        <tr>
            <th>
                WiPopCode
            </th>
            <th>
                Discharge Name
            </th>
            <th>
                Discharge Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var discharge in Model)
        {
            <tr>
                <td>
                    @discharge.WiPopCode
                </td>
                <td>
                    @discharge.Name
                </td>
                <td>
                    @discharge.Description
                </td>
                <td class="nowrap-text">
                   
                    <a class="btn btn-primary" asp-controller="EncounterStructuredData" asp-action="EditDischarge" asp-route-id="@discharge.DischargeId">Edit</a>
                    <a class="btn btn-danger" asp-controller="EncounterStructuredData" asp-action="DeleteDischarge" asp-route-id="@discharge.DischargeId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    .wrap-text {
        white-space: normal;
        word-wrap: break-word;
    }
    .nowrap-text {
        white-space: nowrap;
    }
    /* Ensure buttons don't wrap */
    .nowrap-text button {
        white-space: nowrap;
    }
</style>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#dischargeTable').DataTable({
                columns: [null, null,null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}
