@model IS_Proj_HIT.Entities.MedicationGenericName
@{
    ViewBag.Title = "Edit Generic Name";
}

<h1>Edit</h1>

<h4>Generic Name</h4>
<hr />
<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="MedicationGenericId" value="@Model.MedicationGenericId" readonly/>
                <div class="form-group col-sm-9">
                    <label asp-for="GenericName" class="control-label">Delivery Route</label>
                    <input asp-for="GenericName" type="text" class="form-control" autocomplete="off" required/>
                    <span asp-validation-for="GenericName" class="text-danger"></span>
                </div>
                <div class="form-group mt-4 col-sm-3">
                    <div class="pt-3">
                        <input asp-for="IsActive" class="form-input" type="checkbox"/>
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
                @if (ViewBag.ErrorMessage != null) {
                    <div class="form-group col-12">
                        <span class="text-danger">@ViewBag.ErrorMessage</span>
                    </div>
                }
                <div class="form-group">
                    <a asp-controller="MedicationDataEntry" asp-action="ViewGenericNames" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Save Changes" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}