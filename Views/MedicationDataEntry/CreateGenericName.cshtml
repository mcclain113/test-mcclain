@model IS_Proj_HIT.Entities.MedicationGenericName
@{
    ViewBag.Title = "Create Generic Name";
}

<h1>Create</h1>

<h4>Generic Name</h4>
<hr />
<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group col-12">
                    <label asp-for="GenericName" class="control-label">Generic Name</label>
                    <input asp-for="GenericName" type="text" class="form-control" autocomplete="off" required/>
                    <span asp-validation-for="GenericName" class="text-danger"></span>
                </div>
                <input asp-for="IsActive" class="form-input" type="hidden" readonly/>
                @if (ViewBag.ErrorMessage != null) {
                    <div class="form-group col-12">
                        <span class="text-danger">@ViewBag.ErrorMessage</span>
                    </div>
                }
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

<div>
    <a asp-controller="MedicationDataEntry" asp-action="ViewGenericNames">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}