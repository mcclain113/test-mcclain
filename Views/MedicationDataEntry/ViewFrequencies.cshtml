@model List<IS_Proj_HIT.Entities.MedicationFrequency>

@{
    ViewData["Title"] = "Medication Frequencies";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="MedicationDataEntry" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Medication Frequencies
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="MedicationDataEntry" asp-action="CreateFrequency">Create New</a>
</p>

<table class="stripe nowrap" id="frequencyTable">
    <thead>
        <tr>
            <th>
                Frequency
            </th>
            <th>
                Code
            </th>
            <th>
                Last Modified
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var frequency in Model)
        {
            <tr>
                <td>
                    @frequency.FrequencyDescription
                </td>
                <td>
                    @frequency.FrequencyCode
                </td>
                <td>
                    @frequency.LastUpdate.ToString("MM/dd/yyyy")
                </td>
                <td>
                    <a class="btn btn-primary" asp-controller="MedicationDataEntry" asp-action="EditFrequency" asp-route-id="@frequency.MedicationFrequencyId">Edit</a>
                    <a class="btn btn-danger" asp-controller="MedicationDataEntry" asp-action="DeleteFrequency" asp-route-id="@frequency.MedicationFrequencyId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#frequencyTable').DataTable({
                columns: [null, null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                lengthChange: false,
                language: {
                    emptyTable: 'No medication frequencies found'
                }
            });
        });
    </script>
}