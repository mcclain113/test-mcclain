@model List<IS_Proj_HIT.Entities.MedicationGenericName>

@{
    ViewData["Title"] = "Medication Generic Names";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="MedicationDataEntry" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Medication Generic Names
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="MedicationDataEntry" asp-action="CreateGenericName">Create New</a>
</p>

<table class="stripe nowrap" id="genericNameTable">
    <thead>
        <tr>
            <th>
                Generic Name
            </th>
            <th>
                Active
            </th>
            <th>
                Last Modified
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var genericName in Model)
        {
            @* If the table is not active, grey out the row *@
            <tr class=@(genericName.IsActive ? "" : "bg-secondary")>
                <td>
                    @genericName.GenericName
                </td>
                <td>
                    @(genericName.IsActive ? "Yes" : "No")
                </td>
                <td>
                    @genericName.ModifiedDate.ToString("MM/dd/yyyy")
                </td>
                <td>
                    <a class="btn btn-primary" asp-controller="MedicationDataEntry" asp-action="EditGenericName" asp-route-id="@genericName.MedicationGenericId">Edit</a>
                    <a class="btn btn-danger" asp-controller="MedicationDataEntry" asp-action="DeleteGenericName" asp-route-id="@genericName.MedicationGenericId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#genericNameTable').DataTable({
                columns: [null, null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                lengthChange: false,
                language: {
                    emptyTable: 'No medication generic names found'
                }
            });
        });
    </script>
}