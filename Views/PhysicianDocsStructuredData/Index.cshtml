@{
    ViewBag.Title = "Physician Documents Data Entry";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="Administration" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Physician Documents Data Entry Management
</h3>
</div>

<div class="container">
    <div class="row">
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="PhysicianDocsStructuredData" asp-action="ViewNoteTypes">Note Types</a>
                </div>
            </div>
        </div>

        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="PhysicianDocsStructuredData" asp-action="ViewVisitTypes">Visit Types</a>
                </div>
            </div>
        </div>

        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="PhysicianDocsStructuredData" asp-action="ViewPriorities">Priority</a>
                </div>
            </div>
        </div>
    </div>
</div>