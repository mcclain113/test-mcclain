@model List<IS_Proj_HIT.Entities.Priority>

@{
    ViewData["Title"] = "Priorities";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="PhysicianDocsStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Priorities
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PhysicianDocsStructuredData" asp-action="CreatePriority">Create New</a>
</p>

<table class="stripe nowrap" id="priorityTable">
    <thead>
        <tr>
            <th>
                Priority Name
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var priority in Model)
        {
            <tr>
                <td>
                    @priority.PriorityName
                </td>

                <td>
                    <a class="btn btn-primary" asp-controller="PhysicianDocsStructuredData" asp-action="EditPriority" asp-route-id="@priority.PriorityId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PhysicianDocsStructuredData" asp-action="DeletePriority" asp-route-id="@priority.PriorityId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#priorityTable').DataTable({
                columns: [null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}