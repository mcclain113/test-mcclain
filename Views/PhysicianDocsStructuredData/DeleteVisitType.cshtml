@model IS_Proj_HIT.ViewModels.PhysicianStructuredData.PhysicianDocsStructuredDataViewModel
@{
    ViewData["Title"] = "Delete Visit Type";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Note Type</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                
                <input type="hidden" asp-for="VisitType.VisitTypeId" value="@Model.VisitType.VisitTypeId" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="VisitType.Name" class="control-label">Visit Type Name</label>
                    <input asp-for="VisitType.Name" class="form-control" maxlength="100" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <a asp-controller="PhysicianDocsStructuredData" asp-action="ViewVisitTypes" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

<div>
    <a asp-controller="PhysicianDocsStructuredData" asp-action="ViewVisitTypes">Back to List</a>
</div>