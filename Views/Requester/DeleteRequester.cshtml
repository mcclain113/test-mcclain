@using IS_Proj_HIT.Entities
@model IS_Proj_HIT.ViewModels.RequestersViewModel
@{
    ViewData["Title"] = "Delete Requester";
}

<div class="card mt-1" style="border:none;">
    <form method="post">
        <input type="hidden" asp-for="Requester.RequesterId" value="@Model.Requester.RequesterId"readonly />
        <input type="hidden" asp-for="Address.AddressId" />

    <div class="card-header requestDetailData">
        <h3>
            Delete Requester
        </h3>
    </div>
    
    <div class="card-body bg-light" id="viewMode">
        <div class="container">
                <h3 class="error">@ViewData["RegularMessage"]</h3>
                <h3 class="error">@ViewData["ErrorMessage"]</h3>
            <div class="row mt-3">
                <div class="col-4 ">
                    First Name: <b>@Model.Requester.FirstName</b>
                </div>
                <div class="col-4">
                    Last Name: <b>@Model.Requester.LastName</b>
                </div>
                <div class="col-4">
                    Company: <b>@Model.Requester.CompanyName</b>
                </div>
            </div>
            <hr />
            <div class="row mt-3 ml-1">
                <div class="form-group">
                    <a asp-controller="Requester" asp-action="ViewRequesters" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Requester" class="ml-3 btn btn-primary" />
                </div>
            </div>
        </div>
    </div>
    </form>
</div>