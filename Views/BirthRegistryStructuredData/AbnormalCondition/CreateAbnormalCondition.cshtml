@model IS_Proj_HIT.Entities.AbnormalCondition
@{
    ViewBag.Title = "Create Abnormal Condition";
}

<h1>Create</h1>

<h4>Abnormal Condition</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group col-sm-6">
                    <label asp-for="AbnormalConditionName" class="control-label">Abnormal Condition Name</label>
                    <input asp-for="AbnormalConditionName" 
                        class="form-control" maxlength="75" required
                        placeholder="Example:  Assisted ventilation..." />
                    <span asp-validation-for="AbnormalConditionName" class="text-danger"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-sm-12">
                    <label asp-for="AbnormalConditionDescription" class="control-label">Abnormal Condition Description</label>
                    <textarea asp-for="AbnormalConditionDescription" 
                        class="form-control" maxlength="300"
                        placeholder="Example:  Infant given manual breaths..." ></textarea>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="BirthRegistryStructuredData" asp-action="ViewAbnormalConditions">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}