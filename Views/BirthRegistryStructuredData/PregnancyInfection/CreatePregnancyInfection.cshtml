@model IS_Proj_HIT.Entities.PregnancyInfection
@{
    ViewBag.Title = "Create Pregnancy Infection";
}

<h1>Create</h1>

<h4>Pregnancy Infection</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group col-sm-6">
                    <label asp-for="InfectionName" class="control-label">Pregnancy Infection Name</label>
                    <input asp-for="InfectionName" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Hepatitis B" />
                    <span asp-validation-for="InfectionName" class="text-danger"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-sm-12">
                    <label asp-for="InfectionDescription" class="control-label">Pregnancy Infection Description</label>
                    <textarea asp-for="InfectionDescription" 
                        class="form-control" maxlength="200"
                        placeholder="Example:  HBV serum hepatitis" ></textarea>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="BirthRegistryStructuredData" asp-action="ViewPregnancyInfections">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}