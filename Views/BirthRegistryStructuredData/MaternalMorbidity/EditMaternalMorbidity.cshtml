@model IS_Proj_HIT.Entities.MaternalMorbidity
@{
    ViewBag.Title = "Edit MaternalMorbidity";
}

<h1>Edit</h1>

<h4>Maternal Morbidity</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="MaternalMorbidityId" value="@Model.MaternalMorbidityId" readonly/>
                <div class="form-group col-sm-6">
                    <label asp-for="MaternalMorbidityName" class="control-label">Maternal Morbidity Name</label>
                    <input asp-for="MaternalMorbidityName" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Maternal transfusion" />
                    <span asp-validation-for="MaternalMorbidityName" class="text-danger"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-sm-12">
                    <label asp-for="MaternalMorbidityDescription" class="control-label">Maternal Morbidity Description</label>
                    <textarea asp-for="MaternalMorbidityDescription" 
                        class="form-control" maxlength="400"
                        placeholder="Example:  Includes infusion..." ></textarea>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <input type="submit" value="Save Changes" class="btn btn-primary" />
                </div>
            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="BirthRegistryStructuredData" asp-action="ViewMaternalMorbidities">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}