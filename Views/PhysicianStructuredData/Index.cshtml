@{
    ViewBag.Title = "Physician Data Entry";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="Administration" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Physician Data Entry Management
</h3>
</div>

<div class="container">
    <div class="row">
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="PhysicianStructuredData" asp-action="ViewPhysicians">Physician</a>
                </div>
            </div>
        </div>        
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="PhysicianStructuredData" asp-action="ViewPhysicianRoles">Physician Roles</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="PhysicianStructuredData" asp-action="ViewProviderTypes">Provider Types</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4 col-lg-3 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <a class="btn btn-outline-primary" asp-controller="PhysicianStructuredData" asp-action="ViewSpecialties">Specialties</a>
                </div>
            </div>
        </div>
    </div>
</div>