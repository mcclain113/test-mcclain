@model List<IS_Proj_HIT.Entities.Physician>

@{
    ViewData["Title"] = "Physicians";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="PhysicianStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Physicians
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PhysicianStructuredData" asp-action="CreatePhysician">Create New</a>
</p>

<table class="stripe nowrap" id="physicianTable">
    <thead>
        <tr>
            <th>Name</th>
            <th>Credentials</th>
            <th>ProviderType</th>
            <th>Specialty</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var physician in Model)
        {
            <tr>
                <td>@physician.LastName, @physician.FirstName</td>
                <td>@physician.Credentials</td>
                <td>@physician.ProviderType.Name</td>
                <td>@physician.Specialty.Name</td>
                <td>
                    <a class="btn btn-info" asp-controller="PhysicianStructuredData" asp-action="DetailsPhysician" asp-route-id="@physician.PhysicianId">Details</a>
                    <a class="btn btn-primary" asp-controller="PhysicianStructuredData" asp-action="EditPhysician" asp-route-id="@physician.PhysicianId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PhysicianStructuredData" asp-action="DeletePhysician" asp-route-id="@physician.PhysicianId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#physicianTable').DataTable({
                columns: [null, null, null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No Physicians in database.'
                }
            });
        });
    </script>
}