@model IS_Proj_HIT.ViewModels.PhysicianStructuredData.PhysicianStructuredDataViewModel
@{
    ViewBag.Title = "Create Physician Role";
}

<h1>Create</h1>

<h4>Physician Role</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group col-sm-6">
                    <label asp-for="PhysicianRole.Name" class="control-label">Role Name</label>
                    <input asp-for="PhysicianRole.Name" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Admitting" />
                    <span asp-validation-for="PhysicianRole.Name" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="PhysicianRole.Description" class="control-label">Description</label>
                    <input asp-for="PhysicianRole.Description" 
                        class="form-control" maxlength="100" 
                        placeholder="Example:  Provider responsible for the admission order"/>
                    <span asp-validation-for="PhysicianRole.Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>

            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="PhysicianStructuredData" asp-action="ViewPhysicianRoles">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}