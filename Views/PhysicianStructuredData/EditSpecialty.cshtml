@model IS_Proj_HIT.ViewModels.PhysicianStructuredData.PhysicianStructuredDataViewModel
@{
    ViewBag.Title = "Edit Specialty";
}

<h1>Edit</h1>

<h4>Specialty</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Specialty.SpecialtyId" value="@Model.Specialty.SpecialtyId" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="Specialty.Name" class="control-label">Specialty</label>
                    <input asp-for="Specialty.Name" class="form-control" maxlength="100" required />
                    <span asp-validation-for="Specialty.Name" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="Specialty.Description" class="control-label">Specialty Description</label>
                    <input asp-for="Specialty.Description" class="form-control" maxlength="100" />
                    <span asp-validation-for="Specialty.Description" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <a asp-controller="PhysicianStructuredData" asp-action="ViewSpecialties" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Save Changes" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}