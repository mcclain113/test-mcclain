@model List<IS_Proj_HIT.Entities.PhysicianRole>

@{
    ViewData["Title"] = "Physician Role";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="PhysicianStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Physician Roles
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PhysicianStructuredData" asp-action="CreatePhysicianRole">Create New</a>
</p>

<table class="stripe nowrap" id="physicianRoleTable">
    <thead>
        <tr>
            <th>
                Name
            </th>
            <th>
                Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var physicianRole in Model)
        {
            <tr>
                <td>
                    @physicianRole.Name
                </td>
                <td>
                    @physicianRole.Description
                </td>
                <td>
                   
                    <a class="btn btn-primary" asp-controller="PhysicianStructuredData" asp-action="EditPhysicianRole" asp-route-id="@physicianRole.PhysicianRoleId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PhysicianStructuredData" asp-action="DeletePhysicianRole" asp-route-id="@physicianRole.PhysicianRoleId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#physicianRoleTable').DataTable({
                columns: [null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found.'
                }
            });
        });
    </script>
}