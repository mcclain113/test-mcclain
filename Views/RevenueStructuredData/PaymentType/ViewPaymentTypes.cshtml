@model List<IS_Proj_HIT.Entities.PaymentType>

@{
    ViewData["Title"] = "Payment Types";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="RevenueStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Payment Types
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="RevenueStructuredData" asp-action="CreatePaymentType">Create New</a>
</p>

<table class="stripe nowrap" id="paymentTypeTable">
    <thead>
        <tr>
            <th>
                Payment Type Name
            </th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var paymentType in Model)
        {
            <tr>
                <td>
                    @paymentType.PaymentType1
                </td>
                

                <td>
                   
                    <a class="btn btn-primary" asp-controller="RevenueStructuredData" asp-action="EditPaymentType" asp-route-id="@paymentType.PaymentTypeId">Edit</a>
                    <a class="btn btn-danger" asp-controller="RevenueStructuredData" asp-action="DeletePaymentType" asp-route-id="@paymentType.PaymentTypeId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#paymentTypeTable').DataTable({
                columns: [null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}