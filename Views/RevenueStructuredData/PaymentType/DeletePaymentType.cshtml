@model IS_Proj_HIT.ViewModels.RevenueStructuredDataViewModel
@{
    ViewBag.Title = "Delete Payment Type";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Payment Type</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="PaymentType.PaymentTypeId" value="@Model.PaymentType.PaymentTypeId" readonly/>
                
                <div class="form-group col-sm-6">
                    <label asp-for="PaymentType.PaymentType1" class="control-label">Payment Type Name</label>
                    <input asp-for="PaymentType.PaymentType1" 
                        class="form-control" maxlength="20" required
                        placeholder="Example:  Cash" />
                    <span asp-validation-for="PaymentType.PaymentType1" class="text-danger"></span>
                </div>
                
            </div>

            <div class="form-row"> 
                <div>
                    <a class="btn btn-outline-danger" asp-controller="RevenueStructuredData" asp-action="ViewPaymentTypes">Discard Changes</a>
                </div>           
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>

        </form>
    </div>
</div>




@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
