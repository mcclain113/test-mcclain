@model IS_Proj_HIT.ViewModels.RevenueStructuredDataViewModel
@{
    ViewBag.Title = "Create Disclosure Fee Type";
}

<h1>Create</h1>

<h4>Disclosure Fee Type</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post" id="disclosureFeeTypeForm">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group col-sm-2">
                    <label asp-for="DisclosureFeeType.SortOrder" class="control-label">Sort Order</label>
                    <input asp-for="DisclosureFeeType.SortOrder" type="number" id="SortOrder"
                        class="form-control" maxlength="10" required
                        placeholder="Example:  5" step="1" min="0" />
                    <span asp-validation-for="DisclosureFeeType.SortOrder" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-4">
                    <label asp-for="DisclosureFeeType.FeeAmount" class="control-label">Fee Amount</label>
                    <input asp-for="DisclosureFeeType.FeeAmount" type="number"
                        class="form-control" maxlength="10" required
                        placeholder="Example:  2.54" step="0.01" min="0" max="99999999.99"/>
                    <span asp-validation-for="DisclosureFeeType.FeeAmount" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="DisclosureFeeType.FeeDescription" class="control-label">Fee Description</label>
                    <input asp-for="DisclosureFeeType.FeeDescription" 
                        class="form-control" maxlength="200" required 
                        placeholder="Example:  Pages 1 to 25"/>
                    <span asp-validation-for="DisclosureFeeType.FeeDescription" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-sm-12">
                    <label asp-for="DisclosureFeeType.Comments" class="control-label">Comments</label>
                    <input asp-for="DisclosureFeeType.Comments" class="form-control" maxlength="200" placeholder="Example:  per image"/>
                    <span asp-validation-for="DisclosureFeeType.Comments" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-sm-6">
                    <label asp-for="DisclosureFeeType.EffectiveDate" class="control-label"></label>
                    <input asp-for="DisclosureFeeType.EffectiveDate" class="form-control" type="date" required/>
                    <span asp-validation-for="DisclosureFeeType.EffectiveDate" class="text-danger"></span>
                </div>                
            
                <div class="form-group col-sm-6">
                    <label asp-for="DisclosureFeeType.ExpirationDate" class="control-label">Expiration Date</label>
                    <input asp-for="DisclosureFeeType.ExpirationDate" class="form-control" type="date"/>
                    <span asp-validation-for="DisclosureFeeType.ExpirationDate" class="text-danger"></span>
                </div>
                
            </div>

            <div class="form-row">            
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" id="btnSave" />
                </div>
            </div>

        </form>
    </div>
</div>


<div>
    <a asp-controller="RevenueStructuredData" asp-action="ViewDisclosureFeeTypes">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/disclosureFeeType.js"></script>
}
