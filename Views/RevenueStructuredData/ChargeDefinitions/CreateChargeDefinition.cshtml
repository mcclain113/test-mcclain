@model IS_Proj_HIT.ViewModels.RevenueStructuredDataViewModel
@{
    ViewData["Title"] = "Create Charge Definition";
}

<h1>Create</h1>

<h4>Charge Definition</h4>
<hr/>
<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group col-sm-12">
                    <label asp-for="ChargeDefinition.LongDescription" class="control-label">Long Description</label>
                    <input asp-for="ChargeDefinition.LongDescription"
                        type="text" 
                        class="form-control" maxlength="200"
                        placeholder="Example:  Basic Metabolic Panel (glucose, calcium, BUN, creatinine, sodium, potassium, chloride, and carbon dioxide) (200 characters allowed)" />
                    <span asp-validation-for="ChargeDefinition.LongDescription" class="text-danger"></span>
                </div>

                <div class="form-group col-sm-4">
                    <label asp-for="ChargeDefinition.ShortDescription" class="control-label">Short Description</label>
                    <input asp-for="ChargeDefinition.ShortDescription" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Basic Metabolic Panel (50 characters allowed)" />
                    <span asp-validation-for="ChargeDefinition.ShortDescription" class="text-danger"></span>
                </div>

                <div class="form-group col-sm-4">
                    <label asp-for="ChargeDefinition.ChargeAmount" class="control-label">Charge Amount</label>
                    <input asp-for="ChargeDefinition.ChargeAmount" 
                        class="form-control" step="0.01" placeholder="0.00" required/>
                    <span asp-validation-for="ChargeDefinition.ChargeAmount" class="text-danger"></span>
                </div>

                <div class="form-group col-sm-4">
                    <label asp-for="ChargeDefinition.ServiceCode" class="control-label">Service Code</label>
                    <input asp-for="ChargeDefinition.ServiceCode" 
                        class="form-control" maxlength="10" 
                        placeholder="Example:  Future use" />
                    <span asp-validation-for="ChargeDefinition.ServiceCode" class="text-danger"></span>
                </div>

                <div class="form-group col-sm-4">
                    <label  class="control-label" asp-for="ChargeDefinition.DepartmentID">Select Department</label>
                    <select class="form-control" asp-for="ChargeDefinition.DepartmentID" asp-items="ViewBag.DepartmentID"></select>
                    <span asp-validation-for="ChargeDefinition.DepartmentID" class="text-danger"></span>
                </div>

                <div class="form-group col-sm-4">
                    <label  class="control-label" asp-for="ChargeDefinition.RevenueCodeID">Select Revenue Code</label>
                    <select class="form-control" asp-for="ChargeDefinition.RevenueCodeID" asp-items="ViewBag.RevenueCodeID"></select>
                    <span asp-validation-for="ChargeDefinition.RevenueCodeID" class="text-danger"></span>
                </div>

                <div class="form-group col-sm-4">
                    <label  class="control-label" asp-for="ChargeDefinition.DateActivated">Date Activated</label>
                    <input asp-for="ChargeDefinition.DateActivated" class="form-control" type="datetime-local"/>
                    <span asp-validation-for="ChargeDefinition.DateActivated" class="text-danger"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <input type="submit" value="Create" class="btn btn-primary ml-2"/>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

<div>
    <a asp-controller="RevenueStructuredData" asp-action="ViewChargeDefinitions">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}