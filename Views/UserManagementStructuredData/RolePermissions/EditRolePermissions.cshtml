@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel

@{
    ViewData["Title"] = "Edit Role Permissions";
    var permissionHeaders = ViewData["Permissions"] as List<string>;
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="ViewRolePermissions">
            <i class="fa fa-arrow-left "></i>
        </a>
        Edit
    </h3>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6"> 
            <h4>Edit Permissions for Role: <b class="ml-3">@Model.RoleName</b></h4>
            <hr />
            <form asp-action="EditRolePermissions" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="RoleName" value="@Model.RoleName" />

                <table class="table table-bordered stripe"> <!-- id removed so dataTable.js not currently applied -->
                    <thead>
                        <tr>
                            <th>Module / Form</th>
                            <th>Select Access</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var moduleForm in permissionHeaders)
                        {
                            <tr>
                                <td>@moduleForm</td>
                                <td>
                                    @foreach(var permission in Model.Permissions.Where(p => p.Contains(moduleForm, StringComparison.OrdinalIgnoreCase)).ToList())
                                    {
                                        <div style="display: inline-flex; align-items: center; margin-bottom: 5px; justify-content: flex-start;">
                                            <input type="checkbox" 
                                                name="Permissions" 
                                                value="@permission.Split('|')[0]@(permission.Contains("|Selected") ? "|Selected" : "")"
                                                @(permission.Contains("|Selected") ? "checked" : "") 
                                                class="mr-2" />
                                            <label style="margin: 0;" class="mr-3">@permission.Split('|')[0].Replace(moduleForm,"").Trim()</label>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>
            <div class="mt-3">
                <a asp-controller="UserManagementStructuredData" asp-action="ViewRolePermissions">Back to List</a>
            </div>
        </div>
    </div>
</div>
@section scripts{
    <script>
        // DataTable Documentation found here: https://datatables.net/
        $(document).ready(function () {
            // Creates DataTable
            $('#editRolePermissionTable').DataTable({
                // Auto-detect the number of columns
                columnDefs: [
                    {
                        targets: '_all', // Applies settings to all columns
                        orderable: true, // Allows ordering on all columns
                        searchable: true, // Enables search on all columns
                    }
                ],
                paging: true, // Enable pagination
                info: true,   // Enable table information display below the table
                searching: true, // Enable global search
                autoWidth: false, // Prevent fixed width for dynamic columns
                pageLength: 25,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}