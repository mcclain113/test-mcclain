@model List<IS_Proj_HIT.Entities.Program>

@{
    ViewData["Title"] = "Programs";
    var userPermissions = ViewData["UserPermissions"] as List<string>;
    var requiredUserManagementPermissions = new[]{"StructuredDataAdd","StructuredDataEdit","StructuredDataDelete","StructuredDataView"};
    var requiredRoleAssignmentPermissions = new[]{"SecurityAssignRole","SecurityRemoveRole"};
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Programs
    </h3>
</div>

@if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)))
{
    <p>
        <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="CreateProgram">Create New</a>
    </p>
}

<table class="stripe nowrap" id="programTable">
    <thead>
        <tr>
            <th>Program Name</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var program in Model)
        {
            <tr>
                <td>@program.Name</td>
                <td>
                    <!-- Explicitly check if IsActive has a value and handle true, false and null separately -->
                    @(program.IsActive.HasValue ? (program.IsActive.Value ? "Active" : "Inactive") : "Unknown")
                </td>

                <td>
                    @if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)))
                    {
                        <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="EditProgram" asp-route-id="@program.ProgramId">Edit</a>
                    }
                    @if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)))
                    {
                        <a class="btn btn-danger" asp-controller="UserManagementStructuredData" asp-action="DeleteProgram" asp-route-id="@program.ProgramId">Delete</a>
                    }
                    @if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)) || userPermissions.Any(permission => requiredRoleAssignmentPermissions.Contains(permission)) )
                    {
                        <a class="btn btn-outline-info ml-5" asp-controller="UserManagementStructuredData" asp-action="ViewUsersInProgram" asp-route-programId="@program.ProgramId">Manage Users in Program</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#programTable').DataTable({
                columns: [null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}