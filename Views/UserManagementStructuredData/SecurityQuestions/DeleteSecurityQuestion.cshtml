@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel
@{
    ViewBag.Title = "Delete Security Question";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Security Question</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                
                <input type="hidden" asp-for="SecurityQuestion.SecurityQuestionId" value="@Model.SecurityQuestion.SecurityQuestionId" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="SecurityQuestion.QuestionText" class="control-label">Security Question</label>
                    <input asp-for="SecurityQuestion.QuestionText" class="form-control"  />
                    
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <a asp-controller="UserManagementStructuredData" asp-action="ViewSecurityQuestions" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>      
        </form>
    </div>
</div>