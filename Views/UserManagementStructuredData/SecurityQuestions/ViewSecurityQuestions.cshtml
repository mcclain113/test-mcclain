@model List<IS_Proj_HIT.Entities.SecurityQuestion>

@{
    ViewData["Title"] = "Security Questions";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Security Questions
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="CreateSecurityQuestion">Create New</a>
</p>

<table class="stripe nowrap" id="securityQuestionTable">
    <thead>
        <tr>
            <th>
                Security Question
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var securityQuestion in Model)
        {
            <tr>
                <td>
                    @securityQuestion.QuestionText
                </td>
                <td>
                   
                    <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="EditSecurityQuestion" asp-route-id="@securityQuestion.SecurityQuestionId">Edit</a>
                    <a class="btn btn-danger" asp-controller="UserManagementStructuredData" asp-action="DeleteSecurityQuestion" asp-route-id="@securityQuestion.SecurityQuestionId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#securityQuestionTable').DataTable({
                columns: [null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}