@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel
@{
    ViewBag.Title = "Create Security Question";
}

<h1>Create</h1>

<h4>Security Question</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group col-sm-6">
                    <label asp-for="SecurityQuestion.QuestionText" class="control-label">Security Question</label>
                    <input asp-for="SecurityQuestion.QuestionText" 
                        class="form-control" maxlength="255" required
                        placeholder="Example:  What was the name of your first pet?" />
                    <span asp-validation-for="SecurityQuestion.QuestionText" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>


<div>
    <a asp-controller="UserManagementStructuredData" asp-action="ViewSecurityQuestions">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}