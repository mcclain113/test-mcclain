@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel
@{
    ViewBag.Title = "Delete Role";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Role</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <input type="hidden" asp-for="IdentityRole.Id" />

                <div class="form-group col-sm-6">
                    <label class="control-label">Role Name</label>
                    <span class="form-control">@Model.IdentityRole.Name</span>  
                </div>
            </div>
            <div class="form-row">
                <div class="form-group ml-1">
                    <a asp-controller="UserManagementStructuredData" asp-action="ViewRoles" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>
        </form>
    </div>
</div>
