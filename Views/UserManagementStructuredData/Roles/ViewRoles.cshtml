@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Roles";
    var userPermissions = ViewData["UserPermissions"] as List<string>;
    var requiredUserManagementPermissions = new[]{"StructuredDataAdd","StructuredDataEdit","StructuredDataDelete","StructuredDataView"};
    var requiredRoleAssignmentPermissions = new[]{"SecurityAssignRole","SecurityRemoveRole"};
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Roles
</h3>
</div>

@if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)))
{
    <p>
        <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="CreateRole">Create New</a>
    </p>
}

<table class="stripe nowrap" id="identityRoleTable">
    <thead>
        <tr>
            <th class="col-lg-6">Name</th>
            <th class="col-lg-6"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var identityRole in Model)
        {
            <tr>
                <td>@identityRole.Name</td>
                
                <td>
                    @if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)))
                    {
                        <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="EditRole" asp-route-id="@identityRole.Id">Edit</a>
                    }
                    @if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)))
                    {
                        <a class="btn btn-danger" asp-controller="UserManagementStructuredData" asp-action="DeleteRole" asp-route-id="@identityRole.Id">Delete</a>
                    }
                    @if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)) || userPermissions.Any(permission => requiredRoleAssignmentPermissions.Contains(permission)) )
                    {
                        <a class="btn btn-outline-info ml-5" asp-controller="UserManagementStructuredData" asp-action="ViewUsersInRole" asp-route-id="@identityRole.Id">Manage Users in Role</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#identityRoleTable').DataTable({
                columns: [null,  { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found.'
                }
            });
        });
    </script>
}