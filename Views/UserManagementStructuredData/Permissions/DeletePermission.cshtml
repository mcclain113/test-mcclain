@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel
@{
    ViewBag.Title = "Delete Permission";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Permission</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                
                <input type="hidden" asp-for="AspNetPermission.Id" value="@Model.AspNetPermission.Id" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="AspNetPermission.Id" class="control-label">Permission Name</label>
                    <span asp-for="AspNetPermission.Id" class="form-control">@Model.AspNetPermission.Name</span>
                    <input type="hidden" asp-for="AspNetPermission.Name" value="@Model.AspNetPermission.Name" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-sm-12">
                    <label asp-for="AspNetPermission.Description" class="control-label">Permission Description</label>
                    <span asp-for="AspNetPermission.Description" class="form-control">@Model.AspNetPermission.Description</span>
                    <input type="hidden" asp-for="AspNetPermission.Description" value="@Model.AspNetPermission.Description" />
                </div>

                <div class="form-group">
                    <a asp-controller="UserManagementStructuredData" asp-action="ViewPermissions" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>