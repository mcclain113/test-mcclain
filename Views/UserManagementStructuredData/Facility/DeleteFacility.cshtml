@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel
@{
    ViewBag.Title = "Delete Facility";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Facility</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">

                <input type="hidden" asp-for="Facility.FacilityId" value="@Model.Facility.FacilityId" readonly/>
                <input type="hidden" asp-for="Address.AddressId" />

                <div class="form-group col-sm-4">
                    <label asp-for="Facility.Name" class="control-label">Facility Name</label>
                    <input asp-for="Facility.Name" 
                        class="form-control" maxlength="100" />
                    <span asp-validation-for="Facility.Name" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-4">
                    <label asp-for="Facility.Description" class="control-label">Description</label>
                    <input asp-for="Facility.Description" 
                        class="form-control" maxlength="100" />
                    <span asp-validation-for="Facility.Description" class="text-danger"></span>
                </div>
            </div>
            <div class="form-row">
               <div class="form-group">
                    <a asp-controller="UserManagementStructuredData" asp-action="ViewFacilities" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Facility" class="ml-3 btn btn-primary" />
                </div>
            </div>
            
        </form>
    </div>
</div>
