@model List<IS_Proj_HIT.Entities.Facility>

@{
    ViewData["Title"] = "Facilities";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Facilities
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="CreateFacility">Create New</a>
</p>

<table class="stripe nowrap" id="facilityTable">
    <thead>
        <tr>
            <th>Name</th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var facility in Model)
        {
            <tr>
                <td>@facility.Name</td>
                
                <td>
                    <a class="btn btn-info" asp-controller="UserManagementStructuredData" asp-action="DetailsFacility" asp-route-id="@facility.FacilityId">Details</a>
                    <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="EditFacility" asp-route-id="@facility.FacilityId">Edit</a>
                    <a class="btn btn-danger" asp-controller="UserManagementStructuredData" asp-action="DeleteFacility" asp-route-id="@facility.FacilityId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#facilityTable').DataTable({
                columns: [null,  { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found.'
                }
            });
        });
    </script>
}