@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel
@{
    ViewBag.Title = "Create Facility";
}

<h1>Create</h1>

<h4>Facility</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group col-sm-6">
                    <label asp-for="Facility.Name" class="control-label">Facility Name</label>
                    <input asp-for="Facility.Name" 
                        class="form-control" maxlength="100" required
                        placeholder="Example:  WCTC Healthcare Center Test" />
                    <span asp-validation-for="Facility.Name" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="Facility.Description" class="control-label">Description</label>
                    <input asp-for="Facility.Description" 
                        class="form-control" maxlength="100" 
                        placeholder="Example:  Facility for Healthcare Student access"/>
                    <span asp-validation-for="Facility.Description" class="text-danger"></span>
                </div>
            </div>
 
            <fieldset class="validate-address">
                <div class="form-row">
                    <div class="form-group col-sm-4">
                        <label asp-for="Facility.AddressId" class="control-label">Street Address</label>
                        <input asp-for="@Model.Address.Address1" class="validate form-control" maxlength="50" placeholder="Example:  1757 Nightinggale Avenue"/>
                        <span asp-validation-for="Address.Address1" class="invalid-summary text-danger" style="display:none">Please enter an Address</span>
                    </div>            
                    <div class="form-group col-sm-2">
                        <label asp-for="Facility.AddressId" class="control-label">Suite or Apt #</label>
                        <input asp-for="@Model.Address.Address2" class="validate not-required form-control"maxlength="25" placeholder="Example:  Apt. 14"/>
                    </div>
                    <div class="form-group col-sm-4">
                        <label asp-for="Facility.AddressId" class="control-label">City</label>
                        <input asp-for="@Model.Address.City" id="Address_City" class="validate form-control"maxlength="50" placeholder="Example:  Platteville"/>
                        <span asp-validation-for="Address.City" class="invalid-summary text-danger" style="display:none">Please enter a City</span>
                    </div>
                    <div class="form-group col-sm-2">
                        <label  class="control-label" asp-for="Address.AddressStateID">Select State</label>
                        <select class="form-control" asp-for="Address.AddressStateID" asp-items="ViewBag.StateId"></select>
                    </div>
                    <!-- both State and Country have default values so the 'validate' class is omitted  -->
                </div>

                <div class="form-row">
                    <div class="form-group col-sm-2">
                        <label asp-for="Facility.AddressId" class="control-label">Zip Code</label>
                        <input asp-for="@Model.Address.PostalCode" id="Address_ZipCode" class="validate form-control zipcode"maxlength="11" placeholder="Example:  53036"/>
                        <span asp-validation-for="Address.PostalCode" class="invalid-summary text-danger" style="display:none">Please enter a Postal Code</span>
                    </div>
                    <div class="form-group col-sm-4">
                        <label asp-for="Facility.AddressId" class="control-label">County</label>
                        <input asp-for="@Model.Address.County" class="validate not-required form-control"maxlength="50" placeholder="Example:  Jefferson"/>
                    </div>
                    <div class="form-group col-sm-6">
                        <label  class="control-label" asp-for="Address.CountryId">Select Country</label>
                        <select class="form-control" asp-for="Address.CountryId" asp-items="ViewBag.CountryId"></select>
                    </div>
                </div>
            </fieldset>

            <div class="form-row">
                <div class="form-group col-sm-6">
                    <label asp-for="Facility.Phone" class="control-label">Phone Number</label>
                    <input asp-for="Facility.Phone" class="form-control phone" maxlength="14" placeholder="Example:  (414)-223-5566"/>
                    <span asp-validation-for="Facility.Phone" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">            
                <div class="form-group">
                    <input type="submit" value="Create Facility" class="btn btn-primary" />
                </div>
            </div>

        </form>
    </div>
</div>


<div>
    <a asp-controller="UserManagementStructuredData" asp-action="ViewFacilities">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}