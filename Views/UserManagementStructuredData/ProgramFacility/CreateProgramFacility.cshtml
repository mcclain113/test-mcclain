@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel
@{
    ViewBag.Title = "Create Program Facility";
}

<h1>Create</h1>

<h4>Program Facility</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post" asp-action="CreateProgramFacility">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>        
                <div class="form-group col-sm-6">
                    <label  class="control-label" asp-for="ProgramFacility.FacilityId">Select Facility</label>
                    <select class="form-control" asp-for="ProgramFacility.FacilityId" asp-items="ViewBag.FacilityId"></select>
                    <span asp-validation-for="ProgramFacility.FacilityId" class="text-danger"></span>
                </div>

                <div class="form-group col-sm-6">
                    <label  class="control-label" asp-for="ProgramFacility.ProgramId">Select Program</label>
                    <select class="form-control" asp-for="ProgramFacility.ProgramId" asp-items="ViewBag.ProgramId"></select>
                </div>
            </div>




            <div class="form-row">            
                <div class="form-group">
                    <input type="submit" value="Create Program Facility" class="btn btn-primary" />
                </div>
            </div>

        </form>
    </div>
</div>


<div>
    <a asp-controller="UserManagementStructuredData" asp-action="ViewProgramFacilities">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}