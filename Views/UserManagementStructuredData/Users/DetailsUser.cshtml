@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel

@{
    ViewBag.Title = "Details - User";
    var userPermissions = ViewData["UserPermissions"] as List<string>;
    var requiredUserManagementPermissions = new[]{"StructuredDataAdd","StructuredDataEdit","StructuredDataDelete","StructuredDataView"};
    var requiredRoleAssignmentPermissions = new[]{"SecurityAssignRole","SecurityRemoveRole"};
    var requiredResetPasswordPermissions = new[]{"SecurityResetPassword"};
}

<div  class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="ViewUsers">
            <i class="fa fa-arrow-left "></i>
        </a>
        Users
    </h3>
</div>
<h4>User</h4>
<hr />

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="row">
    <div class="col-md-12">
        @foreach (var user in Model.Users)
        {
            <div class="form-row">
                <div class="form-group col-sm-4">
                    <label asp-for="@user.FirstName" class="control-label">First Name:</label>
                    <span class="form-control">@user.FirstName</span>
                </div>
                <div class="form-group col-sm-4">
                    <label asp-for="@user.LastName" class="control-label">Last Name:</label>
                    <span class="form-control">@user.LastName</span>
                </div>
                <div class="form-group col-sm-4">
                    <label asp-for="@user.Email" class="control-label">Email:</label>
                    <span class="form-control">@user.Email</span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-sm-4">
                    <label asp-for="@user.StartDate" class="control-label">Start Date:</label>
                    <span class="form-control">@user.StartDate.ToString("MM/dd/yyyy")</span>
                </div>
                <div class="form-group col-sm-4">
                    <label asp-for="@user.EndDate" class="control-label">End Date:</label>
                    <span class="form-control">@user.EndDate.ToString("MM/dd/yyyy")</span>
                </div>
            </div>
            <hr />
            <div class="form-row">
                <div class="form-group col-sm-4">
                    <label class="control-label">Programs:</label><br>
                    <ul>
                        @foreach (var program in ViewBag.UserPrograms)
                        {
                            <li>@program.Program.Name</li>
                        }
                    </ul>
                </div>
                <div class="form-group col-sm-4">
                    <label class="control-label">Facilities:</label><br>
                    <ul>
                        @foreach (var userFacility in Model.UserFacilities)
                        {
                            <li>@userFacility.Facility.Name</li>
                        }
                    </ul>
                </div>
                <div class="form-group col-sm-4">
                    <label class="control-label">Roles:</label><br>
                    <ul>
                        @foreach (var role in Model.Roles) 
                        {
                            <li>@role.Name</li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>
</div>
<hr />
<div class="col">
    <div class="row">
        @if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)) || userPermissions.Any(permission => requiredRoleAssignmentPermissions.Contains(permission)) )
        {
            <a asp-controller="UserManagementStructuredData" asp-action="EditUser" asp-route-id="@Model.Users.First().UserId" class="btn btn-primary">Edit User Details</a>
        }
        @if(userPermissions.Any(permission => requiredResetPasswordPermissions.Contains(permission)))
        {
            <form asp-action="ResetPassword" asp-controller="UserManagementStructuredData" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserId" value="@Model.Users.First().UserId" />
                <button type="submit" class="btn btn-outline-warning ml-3" onclick="return confirm('Are you sure you want to reset the password for this user?');">
                    Reset Password
                </button>
            </form>
        }
        @if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)))
        {
            <form asp-action="ResetSecurityQuestions" asp-controller="UserManagementStructuredData" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserId" value="@Model.Users.First().UserId" />
                <button type="submit" class="btn btn-outline-success ml-3" onclick="return confirm('Are you sure you want to reset security questions for this user?');">
                    Reset Security Questions
                </button>
            </form>
        }
        @if(userPermissions.Any(permission => requiredUserManagementPermissions.Contains(permission)))
        {
            <form asp-action="DeleteUser" asp-controller="UserManagementStructuredData" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserId" value="@Model.Users.First().UserId" />
                <button type="submit" class="btn btn-outline-danger ml-3" onclick="return confirm('Are you sure you want to delete this user?');">
                    Delete User
                </button>
            </form>
        }
    </div>
</div>
<div class="mt-3">
    <a asp-controller="UserManagementStructuredData" asp-action="ViewUsers">Back to List</a>
</div>
