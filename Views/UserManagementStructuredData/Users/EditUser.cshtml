@model IS_Proj_HIT.ViewModels.UserManagement.UserManagementStructuredDataViewModel

@{
    ViewBag.Title = "Edit User";
}

<div  class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="UserManagementStructuredData" asp-action="ViewUsers">
            <i class="fa fa-arrow-left "></i>
        </a>
        Users
    </h3>
</div>
<h4 class="mt-3">Edit User</h4>
<hr />

<form asp-controller="UserManagementStructuredData" asp-action="EditUser" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Users[0].UserId" value="@Model.Users.First().UserId" />
    <input type="hidden" name="Users[0].AspNetUsersId" value="@Model.Users.First().AspNetUsersId" />

    <div class="form-row">
        <div class="form-group col-sm-4">
            <label asp-for="@Model.Users[0].FirstName">First Name</label>
            <input asp-for="@Model.Users[0].FirstName" class="form-control" required/>
            <span asp-validation-for="@Model.Users[0].FirstName" class="text-danger"></span>
        </div>
        <div class="form-group col-sm-4">
            <label asp-for="@Model.Users[0].LastName">Last Name</label>
            <input asp-for="@Model.Users[0].LastName" class="form-control" required/>
            <span asp-validation-for="@Model.Users[0].LastName" class="text-danger"></span>
        </div>
        <div class="form-group col-sm-4">
            <label asp-for="@Model.Users[0].Email">Email</label>
            <input asp-for="@Model.Users[0].Email" class="form-control" required/>
            <span asp-validation-for="@Model.Users[0].Email" class="text-danger"></span>
        </div>
    </div>
    <div class="form-row">
        <div class="form-group col-sm-4">
            <label asp-for="@Model.Users[0].StartDate">Start Date</label>
            <input type="date" asp-for="@Model.Users[0].StartDate" class="form-control"/>
        </div>
        <div class="form-group col-sm-4">
            <label asp-for="@Model.Users[0].EndDate">End Date</label>
            <input type="date" asp-for="@Model.Users[0].EndDate" class="form-control" />
        </div>
    </div>
    <hr />
    <div class="form-row">
        <div class="form-group col-sm-4">
            <label>Programs:</label>
            <select id="Programs" name="selectedPrograms" multiple class="form-control dropdowns select-2">
                @foreach (var program in ViewBag.ProgramList)
                {
                    <option value="@program.Value" selected="@(program.Selected ? "selected" : null)">@program.Text</option>
                }
            </select>
        </div>
        <div class="form-group col-sm-4">
            <label>Facilities:</label>
            <select id="Facilities" name="selectedFacilities" multiple class="form-control dropdowns select-2">
                @foreach (var facility in ViewBag.FacilityList)
                {
                    <option value="@facility.Value" selected="@(facility.Selected ? "selected" : null)">@facility.Text</option>
                }
            </select>
        </div>
        <div class="form-group col-sm-4">
            <label>Roles:</label>
            <select id="Roles" name="selectedRoles" multiple class="form-control dropdowns select-2">
                @foreach (var role in ViewBag.RoleList)
                {
                    <option value="@role.Value" selected="@(role.Selected ? "selected" : null)">@role.Text</option>
                }
            </select>
        </div>
    </div>
    <hr />
    <div class="form-row">
        <div class="form-group">
            <a asp-controller="UserManagementStructuredData"  asp-action="DetailsUser" asp-route-id="@Model.Users.First().UserId" class="btn btn-outline-danger">Discard Changes</a>
        </div>
        <div class="form-group">
            <button type="submit" class="btn btn-primary ml-2">Update User</button>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function () {
            $('#Programs').select2({
                placeholder: "Select programs",
                allowClear: false,
                closeOnSelect: false
            });

            $('#Facilities').select2({
                placeholder: "Select facilities",
                allowClear: false,
                closeOnSelect: false
            });

            $('#Roles').select2({
                placeholder: "Select roles",
                allowClear: false,
                closeOnSelect: false
            });
        });
    </script>
}