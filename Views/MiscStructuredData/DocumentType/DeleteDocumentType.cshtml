@model IS_Proj_HIT.ViewModels.MiscStructuredDataViewModel
@{
    ViewBag.Title = "Delete Document Type";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Document Type</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                
                <input type="hidden" asp-for="DocumentType.DocumentTypeID" value="@Model.DocumentType.DocumentTypeID" readonly/>

                <div class="form-group col-sm-6">
                    <label asp-for="DocumentType.DocumentTypeName" class="control-label">Document Type Name</label>
                    <input asp-for="DocumentType.DocumentTypeName" class="form-control" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <a asp-controller="MiscStructuredData" asp-action="ViewDocumentTypes" class="btn btn-outline-danger">Discard Changes</a>
                </div>
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>            
        </form>
    </div>
</div>