@model IS_Proj_HIT.ViewModels.MiscStructuredDataViewModel
@{
    ViewBag.Title = "Edit Document Type";
}

<h1>Edit</h1>

<h4>Document Type</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="DocumentType.DocumentTypeID" value="@Model.DocumentType.DocumentTypeID" readonly/>
                <div class="form-group col-sm-6">
                    <label asp-for="DocumentType.DocumentTypeName" class="control-label">Document Type Name</label>
                    <input asp-for="DocumentType.DocumentTypeName" 
                        class="form-control" maxlength="100" required
                        placeholder="Example:  Patient Photo" />
                    <span asp-validation-for="DocumentType.DocumentTypeName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label class="control-label">Applies to:</label><br/>

                <div class="form-check form-check-inline">
                    <input asp-for="DocumentType.DocumentTypeLevel"
                        class="form-check-input"
                        type="radio"
                        id="levelPatient"
                        name="DocumentType.DocumentTypeLevel"
                        value="Patient" />
                    <label class="form-check-label" for="levelPatient">
                    Patient
                    </label>
                </div>

                <div class="form-check form-check-inline">
                    <input asp-for="DocumentType.DocumentTypeLevel"
                        class="form-check-input"
                        type="radio"
                        id="levelEncounter"
                        name="DocumentType.DocumentTypeLevel"
                        value="Encounter" />
                    <label class="form-check-label" for="levelEncounter">
                    Encounter
                    </label>
                </div>

                <span asp-validation-for="DocumentType.DocumentTypeLevel"
                    class="text-danger"></span>
            </div>
            

            <div class="form-row">
                <div class="form-group">
                    <input type="submit" value="Save Changes" class="btn btn-primary" />
                </div>
            </div>
        </form>
    </div>
</div>


<div>
    <a asp-controller="MiscStructuredData" asp-action="ViewDocumentTypes">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}