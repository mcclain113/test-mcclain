@{
    ViewData["Title"] = "Session expired";
}

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-body text-center">
          <h3 class="card-title mb-3">Your session has expired</h3>
          <p class="card-text">For your security you were signed out after a period of inactivity.</p>
          <p class="card-text">Please sign in again to continue.</p>
          <a class="btn btn-primary mr-2" href="@Url.Action("Login", "Account")">Sign in</a>
          <a class="btn btn-secondary" href="@Url.Action("Index", "Home")">Return to home</a>
        </div>
      </div>
    </div>
  </div>
</div>
