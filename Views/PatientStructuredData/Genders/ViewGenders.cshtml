@model List<IS_Proj_HIT.Entities.Gender>

@{
    ViewData["Title"] = "Genders";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Genders
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreateGender">Create New</a>
</p>

<table class="stripe nowrap" id="genderTable">
    <thead>
        <tr>
            <th>Gender Name</th>
            
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var gender in Model)
        {
            <tr>
                <td>@gender.Name</td>
                
                
                <td>
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditGender" asp-route-id="@gender.GenderId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeleteGender" asp-route-id="@gender.GenderId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#genderTable').DataTable({
                columns: [null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No Genders in database.'
                }
            });
        });
    </script>
}