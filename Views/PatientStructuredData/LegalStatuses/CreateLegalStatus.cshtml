@model IS_Proj_HIT.ViewModels.PatientVm.PatientStructuredDataViewModel
@{
    ViewBag.Title = "Create Legal Status";
}

<h1>Create</h1>

<h4>Legal Status</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group col-sm-3">
                    <label asp-for="LegalStatus.LegalStatusName" class="control-label">Legal Status Name</label>
                    <input asp-for="LegalStatus.LegalStatusName" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Emancipated Minor" />
                    <span asp-validation-for="LegalStatus.LegalStatusName" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-3">
                    <label asp-for="LegalStatus.RequiresLegalGuardian" class="control-label">Requires Legal Guardian?</label>
                    <select asp-for="@Model.LegalStatus.RequiresLegalGuardian" class="form-control">
                                    <option>Select</option>
                                    <option value="1">Yes</option>
                                    <option value="0">No</option>
                                </select>
                </div>
                <div class="form-group col-sm-3">
                    <label asp-for="LegalStatus.IsActive" class="control-label">Active?</label>
                    <select asp-for="@Model.LegalStatus.IsActive" class="form-control">
                                    <option>Select</option>
                                    <option value="1">Yes</option>
                                    <option value="0">No</option>
                                </select>
                </div>
            </div>

            <div class="form-row">            
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </div>

        </form>
    </div>
</div>


<div>
    <a asp-controller="PatientStructuredData" asp-action="ViewLegalStatuses">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}