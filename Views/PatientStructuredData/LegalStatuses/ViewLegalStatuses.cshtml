@model List<IS_Proj_HIT.Entities.LegalStatus>

@{
    ViewData["Title"] = "Legal Statuses";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Legal Statuses
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreateLegalStatus">Create New</a>
</p>

<table class="stripe nowrap" id="legalStatusTable">
    <thead>
        <tr>
            <th>Legal Status Name</th>
            <th>Legal Guardian Required?</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var legalStatus in Model)
        {
            <tr>
                <td>@legalStatus.LegalStatusName</td>
                <td>@(legalStatus.RequiresLegalGuardian ? "Yes" : "No")</td>
                <td>@(legalStatus.IsActive ? "Active" : "Inactive")</td>
                <td>
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditLegalStatus" asp-route-id="@legalStatus.LegalStatusId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeleteLegalStatus" asp-route-id="@legalStatus.LegalStatusId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#legalStatusTable').DataTable({
                columns: [null, null,null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No LegalStatuses in database.'
                }
            });
        });
    </script>
}