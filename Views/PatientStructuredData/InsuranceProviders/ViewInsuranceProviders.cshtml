@model List<IS_Proj_HIT.Entities.InsuranceProvider>

@{
    ViewData["Title"] = "Insurance Providers";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Insurance Providers
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreateInsuranceProvider">Create New</a>
</p>

<table class="stripe nowrap" id="insuranceProviderTable">
    <thead>
        <tr>
            <th>
                Payment Type Name
            </th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var insuranceProvider in Model)
        {
            <tr>
                <td>
                    @insuranceProvider.ProviderName
                </td>
                

                <td>
                   
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditInsuranceProvider" asp-route-id="@insuranceProvider.InsuranceProviderId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeleteInsuranceProvider" asp-route-id="@insuranceProvider.InsuranceProviderId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#insuranceProviderTable').DataTable({
                columns: [null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}