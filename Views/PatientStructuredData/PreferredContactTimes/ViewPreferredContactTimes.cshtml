@model List<IS_Proj_HIT.Entities.PreferredContactTime>

@{
    ViewData["Title"] = "Preferred Contact Time";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Preferred Contact Times
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreatePreferredContactTime">Create New</a>
</p>

<table class="stripe nowrap" id="preferredContactTimeTable">
    <thead>
        <tr>
            <th>
                Preferred Contact Time Name
            </th>
            <th>
                Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var preferredContactTime in Model)
        {
            <tr>
                <td>
                    @preferredContactTime.Name
                </td>
                <td>
                    @preferredContactTime.Description
                </td>
                <td>
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditPreferredContactTime" asp-route-id="@preferredContactTime.ContactTimeId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeletePreferredContactTime" asp-route-id="@preferredContactTime.ContactTimeId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#preferredContactTimeTable').DataTable({
                columns: [null,null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}