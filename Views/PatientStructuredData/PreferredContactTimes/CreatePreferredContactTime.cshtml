@model IS_Proj_HIT.ViewModels.PatientVm.PatientStructuredDataViewModel
@{
    ViewBag.Title = "Create Preferred Contact Time";
}

<h1>Create</h1>

<h4>Preferred Contact Time</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group col-sm-6">
                    <label asp-for="PreferredContactTime.Name" class="control-label">Preferred Contact Time Name</label>
                    <input asp-for="PreferredContactTime.Name" 
                        class="form-control" maxlength="50" required
                        placeholder="Example:  Afternoon - late" />
                    <span asp-validation-for="PreferredContactTime.Name" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="PreferredContactTime.Description" class="control-label">Description</label>
                    <input asp-for="PreferredContactTime.Description" 
                        class="form-control"
                        placeholder="Example:  Not before 2:30 pm" />
                    <span asp-validation-for="PreferredContactTime.Description" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">            
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </div>

        </form>
    </div>
</div>


<div>
    <a asp-controller="PatientStructuredData" asp-action="ViewPreferredContactTimes">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}