@model List<IS_Proj_HIT.Entities.Religion>

@{
    ViewData["Title"] = "Religions";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Religions
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreateReligion">Create New</a>
</p>

<table class="stripe nowrap" id="religionTable">
    <thead>
        <tr>
            <th>
                Religion Name
            </th>
            <th>
                Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var religion in Model)
        {
            <tr>
                <td>
                    @religion.Name
                </td>
                <td>
                    @religion.Description
                </td>
                <td>
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditReligion" asp-route-id="@religion.ReligionId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeleteReligion" asp-route-id="@religion.ReligionId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>


@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#religionTable').DataTable({
                columns: [null,null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}