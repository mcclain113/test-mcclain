@model List<IS_Proj_HIT.Entities.EducationLevel>

@{
    ViewData["Title"] = "Education Levels";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Education Levels
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreateEducationLevel">Create New</a>
</p>

<table class="stripe nowrap" id="educationLevelTable">
    <thead>
        <tr>
            <th>
                ID
            </th>
            <th>
                Education Level Name
            </th>
            <th>
                Description
            </th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var educationLevel in Model)
        {
            <tr>
                <td>
                    @educationLevel.EducationId
                </td>
                <td>
                    @educationLevel.EducationLevelName
                </td>
                <td>
                    @educationLevel.EducationLevelDescription
                </td>

                <td>
                   
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditEducationLevel" asp-route-id="@educationLevel.EducationId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeleteEducationLevel" asp-route-id="@educationLevel.EducationId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#educationLevelTable').DataTable({
                columns: [
                    {visible: false}, 
                    null, 
                    null, 
                    { orderable: false }
                ],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}