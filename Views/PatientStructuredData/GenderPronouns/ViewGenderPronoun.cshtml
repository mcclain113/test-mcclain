@model List<IS_Proj_HIT.Entities.GenderPronoun>

@{
    ViewData["Title"] = "Gender Pronouns";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Gender Pronouns
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreateGenderPronoun">Create New</a>
</p>

<table class="stripe nowrap" id="genderPronounTable">
    <thead>
        <tr>
            <th>Gender Pronouns</th>
            <th>Status</th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var genderPronoun in Model)
        {
            <tr>
                <td>@genderPronoun.GenderPronouns</td>
                <td>@(genderPronoun.IsActive ? "Active" : "Inactive")</td>
                
                <td>
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditGenderPronoun" asp-route-id="@genderPronoun.GenderPronounId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeleteGenderPronoun" asp-route-id="@genderPronoun.GenderPronounId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#genderPronounTable').DataTable({
                columns: [null, null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No Gender Pronouns in database.'
                }
            });
        });
    </script>
}