@model IS_Proj_HIT.ViewModels.PatientVm.PatientStructuredDataViewModel
@{
    ViewBag.Title = "Edit Preferred Mode Of Contact";
}

<h1>Edit</h1>

<h4>Preferred ModeOfContact</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="PreferredModeOfContact.ModeOfContactId" value="@Model.PreferredModeOfContact.ModeOfContactId" readonly />
                
                <div class="form-group col-sm-6">
                    <label asp-for="PreferredModeOfContact.Name" class="control-label">Preferred Mode Of Contact Name</label>
                    <input asp-for="PreferredModeOfContact.Name" 
                        class="form-control" maxlength="100" required />
                    <span asp-validation-for="PreferredModeOfContact.Name" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="PreferredModeOfContact.Description" class="control-label">Description</label>
                    <input asp-for="PreferredModeOfContact.Description" 
                        class="form-control"/>
                </div>
            </div>

            <div class="form-row">            
                <div class="form-group">
                    <input type="submit" value="Edit" class="btn btn-primary" />
                </div>
            </div>

        </form>
    </div>
</div>


<div>
    <a asp-controller="PatientStructuredData" asp-action="ViewPreferredModeOfContacts">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}