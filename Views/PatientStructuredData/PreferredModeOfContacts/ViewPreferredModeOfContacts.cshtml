@model List<IS_Proj_HIT.Entities.PreferredModeOfContact>

@{
    ViewData["Title"] = "Preferred Modes Of Contact";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Preferred Modes Of Contact
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreatePreferredModeOfContact">Create New</a>
</p>

<table class="stripe nowrap" id="preferredModeOfContactTable">
    <thead>
        <tr>
            <th>
                Preferred Mode Of Contact Name
            </th>
            <th>
                Description
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var preferredModeOfContact in Model)
        {
            <tr>
                <td>
                    @preferredModeOfContact.Name
                </td>
                <td>
                    @preferredModeOfContact.Description
                </td>
                <td>
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditPreferredModeOfContact" asp-route-id="@preferredModeOfContact.ModeOfContactId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeletePreferredModeOfContact" asp-route-id="@preferredModeOfContact.ModeOfContactId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>


@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#preferredModeOfContactTable').DataTable({
                columns: [null,null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}