@model List<IS_Proj_HIT.Entities.Ethnicity>

@{
    ViewData["Title"] = "Ethnicities";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Ethnicities
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreateEthnicity">Create New</a>
</p>

<table class="stripe nowrap" id="ethnicityTable">
    <thead>
        <tr>
            <th>Ethnicity</th>
            <th>WiPopCode</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ethnicity in Model)
        {
            <tr>
                <td>@ethnicity.Name</td>
                <td>@ethnicity.WiPopCode</td>
                <td>
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditEthnicity" asp-route-id="@ethnicity.EthnicityId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeleteEthnicity" asp-route-id="@ethnicity.EthnicityId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#ethnicityTable').DataTable({
                columns: [null,null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No Ethnicities in database.'
                }
            });
        });
    </script>
}