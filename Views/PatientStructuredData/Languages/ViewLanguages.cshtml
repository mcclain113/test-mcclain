@model List<IS_Proj_HIT.Entities.Language>

@{
    ViewData["Title"] = "Languages";
}

<div class="row my-3">
<h3>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
        <i class="fa fa-arrow-left "></i>
    </a>
    Languages
</h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreateLanguage">Create New</a>
</p>

<table class="stripe nowrap" id="languageTable">
    <thead>
        <tr>
            <th>Language Name</th>
            
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var language in Model)
        {
            <tr>
                <td>@language.Name</td>
                
                
                <td>
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditLanguage" asp-route-id="@language.LanguageId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeleteLanguage" asp-route-id="@language.LanguageId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#languageTable').DataTable({
                columns: [null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'No Languages in database.'
                }
            });
        });
    </script>
}