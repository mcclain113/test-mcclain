@model IS_Proj_HIT.ViewModels.PatientVm.PatientStructuredDataViewModel
@{
    ViewBag.Title = "Delete Marital Status";
}

<h1>Delete</h1>

<h3>@ViewData["RegularMessage"]</h3>
<h3 class="error">@ViewData["ErrorMessage"]</h3>

<h4>Marital Status</h4>
<hr />

<div class="row">
    <div class="col-md-10">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <input type="hidden" asp-for="MaritalStatus.MaritalStatusId" value="@Model.MaritalStatus.MaritalStatusId" readonly/>
                
                <div class="form-group col-sm-6">
                    <label asp-for="MaritalStatus.Name" class="control-label">Marital Status Name</label>
                    <input asp-for="MaritalStatus.Name" 
                        class="form-control"
                        />
                </div>
                
            </div>

            <div class="form-row"> 
                <div>
                    <a class="btn btn-outline-danger" asp-controller="PatientStructuredData" asp-action="ViewMaritalStatuses">Discard Changes</a>
                </div>           
                <div class="form-group">
                    <input type="submit" value="Delete Item" class="ml-3 btn btn-primary" />
                </div>
            </div>

        </form>
    </div>
</div>