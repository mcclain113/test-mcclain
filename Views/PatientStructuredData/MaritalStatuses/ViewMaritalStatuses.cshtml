@model List<IS_Proj_HIT.Entities.MaritalStatus>

@{
    ViewData["Title"] = "Marital Statuses";
}

<div class="row my-3">
    <h3>
        <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="Index">
            <i class="fa fa-arrow-left "></i>
        </a>
        Marital Statuses
    </h3>
</div>

<p>
    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="CreateMaritalStatus">Create New</a>
</p>

<table class="stripe nowrap" id="maritalStatusTable">
    <thead>
        <tr>
            <th>
                Marital Status Name
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var maritalStatus in Model)
        {
            <tr>
                <td>
                    @maritalStatus.Name
                </td>
                <td>
                    <a class="btn btn-primary" asp-controller="PatientStructuredData" asp-action="EditMaritalStatus" asp-route-id="@maritalStatus.MaritalStatusId">Edit</a>
                    <a class="btn btn-danger" asp-controller="PatientStructuredData" asp-action="DeleteMaritalStatus" asp-route-id="@maritalStatus.MaritalStatusId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts{
    <script>
        // Creates DataTable
        // DataTable Documentation found here: https://datatables.net/
        $(function () {
            $('#maritalStatusTable').DataTable({
                columns: [null, { orderable: false }],
                order: [[0, 'asc']],
                pageLength: 10,
                searching: true,
                language: {
                    emptyTable: 'None found'
                }
            });
        });
    </script>
}