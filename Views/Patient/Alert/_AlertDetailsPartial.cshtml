@model IS_Proj_HIT.ViewModels.Alert.AlertDetailsViewModel
@{
    var userPermissions = ViewData["UserPermissions"] as List<string>;
}

<div class="card" data-modal-title="Alert Details">
    <div class="card-header bg-primary text-white">
        <h4 class="m-0">Alert Details
            @if (userPermissions != null && userPermissions.Contains("AlertEdit"))
            {
                <a class="btn btn-info float-right open-edit"
                    href="@Url.Action("Edit", "Patient", new { id = Model.PatientAlertId, mrn = Model.Mrn })"
                    data-alertid="@Model.PatientAlertId" data-modal-title="Edit Alert">Edit</a>
            }
        </h4>
    </div>

    <div class="card-body bg-light">
        <div class="container">
            <div class="row">
                <div class="col-sm-12 col-lg-4">
                    <label>Alert Type: </label>
                    <span class="font-weight-bold">@Model.AlertTypeName</span>
                </div>
                <div class="col-sm-12 col-lg-4">
                    <label>Active: </label>
                    <span class="font-weight-bold">@(Model.IsActive ? "Yes" : "No")</span>
                </div>            
            </div>
            <hr class="mt-0"/>
            <div class="row">
                <div class="col-sm-4">
                    <label>Created: </label>
                    <span><input asp-for="@Model.LastModified" class="takeawayborder bg-light font-weight-bold" type="text" id="longer" readonly /></span>
                </div>
                <div class="col-sm-4 form-group">
                    <label>Start Date: </label>
                    <span class="font-weight-bold">@Model.StartDate.ToString("MM-dd-yyyy")</span>
                </div>
                <div class="col-sm-4 form-group">
                    <label>End Date: </label>
                    <span class="font-weight-bold">@((Model.EndDate?.ToString("MM-dd-yyyy")) ?? "—")</span>
                </div>
            </div>
            <hr class="mt-0"/>
        
            @if (!string.IsNullOrWhiteSpace(Model.AllergenName) || !string.IsNullOrWhiteSpace(Model.ReactionName))
            {
                <div class="row">
                    <div class="col-sm-4 form-group">
                        <label>Allergen:</label>
                        <span class="font-weight-bold ml-3">@Model.AllergenName</span>
                    </div>
                    <div class="col-sm-4 form-group">
                        <label>Reaction:</label>
                        <span class="font-weight-bold ml-3">@Model.ReactionName</span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.FallRiskName))
            {
                <div class="row">
                    <div class="col-sm-4 form-group">
                        <label>Fall Risk:</label>
                        <span class="font-weight-bold ml-3">@Model.FallRiskName</span>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.RestrictionName))
            {
                <div class="row">
                    <div class="col-sm-4 form-group">
                        <label>Restriction:</label>
                        <span class="font-weight-bold ml-3">@Model.RestrictionName</span>
                    </div>
                </div>
            }
            <hr class="mt-0"/>

            <div class="row">
                <div class="col-sm-12 form-group">
                    <label>Comments: </label>
                    <span class="font-weight-bold">@Model.Comments</span>
                </div>
            </div>
            <hr class="mt-0"/>
    </div>
        <div class="mt-3">
            <a class="btn btn-secondary back-to-list"
                href="@Url.Action("ListAlerts", "Patient", new {mrn = Model.Mrn})"
                data-alertid="@Model.PatientAlertId">Back to Alerts
            </a>
        </div>
    </div>
</div>
    
