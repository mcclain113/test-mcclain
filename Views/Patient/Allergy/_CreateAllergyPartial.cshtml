@model IS_Proj_HIT.ViewModels.Allergy.CreateAllergyViewModel
@{
    
    var allergenList = new SelectList(Model.Allergens, "AllergenId", "AllergenName");
    var reactionList = new SelectList(Model.Reactions, "ReactionId", "Name");
    var medicationList = new SelectList(Model.MedicationGenericNames, "MedicationGenericId", "GenericName");
}

<div class="card" data-modal-title="Create Allergy">
    <div  class="card-header bg-primary text-white">
        <h4>Add a Patient Allergy</h4>
    </div>

    <form asp-action="CreateAllergy" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Mrn" />
        <div class="card-body bg-light">
            <div class="form-group">
                <label asp-for="AllergenId" class="control-label"></label>
                <select asp-for="AllergenId" class="form-control" asp-items="allergenList"  id="allergylist">
                    <option value="">-- select allergen --</option>
                </select>
                <span asp-validation-for="AllergenId" class="text-danger"></span>
            </div>

            <div class="form-group" id="medicationList">
                <label asp-for="GenericMedicationId" class="control-label"></label>
                <select class="form-control meds-select2" id="medicationlist" asp-for="@Model.GenericMedicationId" asp-items="medicationList"><option value="">-- select medication --</option></select>
                <span asp-validation-for="GenericMedicationId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ReactionId" class="control-label"></label>
                <select asp-for="ReactionId" class="form-control" asp-items="reactionList">
                    <option value="">-- select reaction --</option>
                </select>
                <span asp-validation-for="ReactionId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Create</button>
            <div>
                <a asp-action="ListAllergies" asp-route-mrn="@Model.Mrn" class="btn btn-cancel mt-3 back-to-list">Cancel</a>
            </div>
        </div>
    </form>
</div>

@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
    $('.meds-select2').select2({
        width: '100%'
        });

</script>
<script>
    // helper to set/clear validation text in the same spans generated by asp-validation-for
    function setFieldError(propName, message) {
        var $span = $('span[data-valmsg-for="' + propName + '"]');
        $span.text(message);
        $span.addClass('field-validation-error').removeClass('field-validation-valid');
        var $input = $('[name="' + propName + '"]');
        $input.addClass('input-validation-error');
    }

    function clearFieldError(propName) {
        var $span = $('span[data-valmsg-for="' + propName + '"]');
        $span.text('');
        $span.addClass('field-validation-valid').removeClass('field-validation-error');
        var $input = $('[name="' + propName + '"]');
        $input.removeClass('input-validation-error');
    }

    $(function () {
        // hide medication selection initially
        $('#medicationList').hide();

        // when allergen changes show/hide medication selector
        $('#allergylist').on('change', function () {
            var selectedText = $("#allergylist option:selected").text();

            // clear any previous field-level errors for Allergen/Medication
            clearFieldError('AllergenId');
            clearFieldError('GenericMedicationId');

            if (selectedText === 'Medication') {
                $('#medicationList').show();
            } else {
                // reset medication select when not Medication
                $('#medicationlist').val('');
                $('#medicationList').hide();
            }
        });

        // Clear field-level errors when related controls change
        $('#medicationlist').on('change input', function () {
            clearFieldError('GenericMedicationId');
        });

        $('#allergylist').on('change input', function () {
            clearFieldError('AllergenId');
        });

        $('select[name="ReactionId"]').on('change input', function () {
            clearFieldError('ReactionId');
        });

        $('form').on('submit', function (e) {
            // clear previous field-level messages
            clearFieldError('AllergenId');
            clearFieldError('GenericMedicationId');
            clearFieldError('ReactionId');

            var allergenText = $("#allergylist option:selected").text();
            var allergenVal = $('#allergylist').val();
            var reactionVal = $('select[name="ReactionId"]').val();
            var medicationVal = $('#medicationlist').val();

            var hasError = false;

            if (!allergenVal || allergenVal === '') {
                setFieldError('AllergenId', 'Please select an Allergen.');
                hasError = true;
            }

            if (!reactionVal || reactionVal === '') {
                setFieldError('ReactionId', 'Please select a Reaction.');
                hasError = true;
            }

            if (allergenText === 'Medication') {
                if (!medicationVal || medicationVal === '') {
                    setFieldError('GenericMedicationId', 'Please select a Medication.');
                    hasError = true;
                }
            }

            // if client-side check found errors prevent submit and let user fix them,
            // otherwise allow form to submit and let server-side validation run
            if (hasError) {
                e.preventDefault();
                return false;
            }

            // allow submit to continue (server-side will still validate)
            return true;
        });
    });
</script>
