                    </div>
                    <div class="col-2 form-group">
                        <label for="GroupNumber3">Group Number</label>
                        <input asp-for="TertiaryInsurance.GroupNumber" id="GroupNumber3" type="text" class="form-control" placeholder="Group Number" maxlength="20"/>
                    </div>
                    <div class="col-3 form-group">
                        <label for="PlanName3">Plan Name</label>
                        <input asp-for="TertiaryInsurance.PlanName" id="PlanName3" type="text" class="validate3 not-required form-control" placeholder="Plan Name" maxlength="100" />
