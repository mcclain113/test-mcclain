</div>
<!-- Nested Accordion Ends Here -->

<div @(!ViewBag.ViewPatientDetails ? "hidden" : "")>
    <div class="row">
        <div class="col-4 ml-3">
            <h5><u>Primary Insurance</u></h5>
            <div class="row">
                <label>Guarantor: </label>
                <span class="data ml-2">@(Model.PrimaryInsurance?.Guarantor ?? "")</span> 
            </div>
            <div class="row">
                <label>Insurance Provider: </label>
                <span class="data ml-2">@(Model.PrimaryInsurance?.InsuranceProvider?.ProviderName ?? "")</span>
            </div>
            <div class="row">
                <label>Subscriber: </label>
                <span class="data ml-2">@(Model.PrimaryInsurance?.Subscriber ?? "")</span>
            </div>
            <div class="row">
                @if(Model.PrimaryInsurance?.Relationship != null)
                {
                <label>Relationship: </label>
                <span class="data ml-2">@(Model.PrimaryInsurance?.Relationship.Name ?? "N/A")</span>
                }
                else 
                {
                <label>Relationship: </label>
                <span class="data ml-2"></span>
                }
            </div>
            <div class="row">
                <label>Subscriber Number: </label>
                <span class="data ml-2">@(Model.PrimaryInsurance?.SubscriberNumber ?? "")</span> 
            </div>
            <div class="row">
                <label>Group Number: </label>
                <span class="data ml-2">@(Model.PrimaryInsurance?.GroupNumber ?? "")</span>
            </div>
            <div class="row">
                <label>Plan Name: </label>
                <span class="data ml-2">@(Model.PrimaryInsurance?.PlanName ?? "")</span>
            </div>
            <div class="row">
                <label>Plan Number: </label>
                <span class="data ml-2">@(Model.PrimaryInsurance?.PlanNumber ?? "")</span> 
            </div>
            <div class="row">
                @if(Model.PrimaryInsurance?.EffectiveDate.ToString("MM/dd/yyyy") == "01/01/0001")
                {
                    <label>Effective Date: </label>
                    <span class="data ml-2"></span>
                }
                else
                {
                    <label>Effective Date: </label>
                    <span class="data ml-2">@(Model.PrimaryInsurance?.EffectiveDate.ToString("MM/dd/yyyy") ?? "")</span>
                }  
            </div>
            <div class="row">
                <label>Notes: </label>
                <span class="data ml-2">@(Model.PrimaryInsurance?.Notes ?? "")</span> 
            </div>
        </div> <!-- close the Primary Insurance column  -->
        
        @if(Model.SecondaryInsurance != null)
        {
            <div class="col-4 ml-3">
                <h5><u>Secondary Insurance</u></h5>
                <div class="row">
                    <label>Guarantor: </label>
                    <span class="data ml-2">@(Model.SecondaryInsurance?.Guarantor ?? "")</span> 
                </div>
                <div class="row">
                    <label>Insurance Provider: </label>
                    <span class="data ml-2">@(Model.SecondaryInsurance?.InsuranceProvider?.ProviderName ?? "")</span>
                </div>
                <div class="row">
                    <label>Subscriber: </label>
                    <span class="data ml-2">@(Model.SecondaryInsurance?.Subscriber ?? "")</span>
                </div>
                <div class="row">
                    @if(Model.SecondaryInsurance?.Relationship != null)
                    {
                    <label>Relationship: </label>
                    <span class="data ml-2">@(Model.SecondaryInsurance?.Relationship.Name ?? "N/A")</span>
                    }
                    else 
                    {
                    <label>Relationship: </label>
                    <span class="data ml-2"></span>
                    }
                </div>
                <div class="row">
                    <label>Subscriber Number: </label>
                    <span class="data ml-2">@(Model.SecondaryInsurance?.SubscriberNumber ?? "")</span> 
                </div>
                <div class="row">
                    <label>Group Number: </label>
                    <span class="data ml-2">@(Model.SecondaryInsurance?.GroupNumber ?? "")</span>
                </div>
                <div class="row">
                    <label>Plan Name: </label>
                    <span class="data ml-2">@(Model.SecondaryInsurance?.PlanName ?? "")</span>
                </div>
                <div class="row">
                    <label>Plan Number: </label>
                    <span class="data ml-2">@(Model.SecondaryInsurance?.PlanNumber ?? "")</span> 
                </div>
                <div class="row">
                    @if(Model.SecondaryInsurance?.EffectiveDate.ToString("MM/dd/yyyy") == "01/01/0001")
                    {
                        <label>Effective Date: </label>
                        <span class="data ml-2"></span>
                    }
                    else
                    {
                        <label>Effective Date: </label>
                        <span class="data ml-2">@(Model.SecondaryInsurance?.EffectiveDate.ToString("MM/dd/yyyy") ?? "")</span>
                    }  
                </div>
                <div class="row">
                    <label>Notes: </label>
                    <span class="data ml-2">@(Model.SecondaryInsurance?.Notes ?? "")</span> 
                </div>
            </div> <!-- close the SecondaryInsurance column  -->
        }

        @if(Model.TertiaryInsurance != null)
        {
            <div class="col-3 ml-3">
                <h5><u>Tertiary Insurance</u></h5>
                <div class="row">
                    <label>Guarantor: </label>
                    <span class="data ml-2">@(Model.TertiaryInsurance?.Guarantor ?? "")</span> 
                </div>
                <div class="row">
                    <label>Insurance Provider: </label>
                    <span class="data ml-2">@(Model.TertiaryInsurance?.InsuranceProvider?.ProviderName ?? "")</span>
                </div>
                <div class="row">
                    <label>Subscriber: </label>
                    <span class="data ml-2">@(Model.TertiaryInsurance?.Subscriber ?? "")</span>
                </div>
                <div class="row">
                    @if(Model.TertiaryInsurance?.Relationship != null)
                    {
                    <label>Relationship: </label>
                    <span class="data ml-2">@(Model.TertiaryInsurance?.Relationship.Name ?? "N/A")</span>
                    }
                    else 
                    {
                    <label>Relationship: </label>
                    <span class="data ml-2"></span>
                    }
                </div>
                <div class="row">
                    <label>Subscriber Number: </label>
                    <span class="data ml-2">@(Model.TertiaryInsurance?.SubscriberNumber ?? "")</span> 
                </div>
                <div class="row">
                    <label>Group Number: </label>
                    <span class="data ml-2">@(Model.TertiaryInsurance?.GroupNumber ?? "")</span>
                </div>
                <div class="row">
                    <label>Plan Name: </label>
                    <span class="data ml-2">@(Model.TertiaryInsurance?.PlanName ?? "")</span>
                </div>
                <div class="row">
                    <label>Plan Number: </label>
                    <span class="data ml-2">@(Model.TertiaryInsurance?.PlanNumber ?? "")</span> 
                </div>
                <div class="row">
                    @if(Model.TertiaryInsurance?.EffectiveDate.ToString("MM/dd/yyyy") == "01/01/0001")
                    {
                        <label>Effective Date: </label>
                        <span class="data ml-2"></span>
                    }
                    else
                    {
                        <label>Effective Date: </label>
                        <span class="data ml-2">@(Model.TertiaryInsurance?.EffectiveDate.ToString("MM/dd/yyyy") ?? "")</span>
                    }  
                </div>
                <div class="row">
                    <label>Notes: </label>
                    <span class="data ml-2">@(Model.TertiaryInsurance?.Notes ?? "")</span> 
                </div>
            </div> <!-- close the Tertiary Insurance column  -->
        }
    </div> <!-- close the row  -->
</div> <!-- close the entire details view  -->

<style>
    .info{
        position: relative;
        bottom: 5px;
        color:  black;
        text-decoration: none;
    }
    .info:hover{
        cursor: pointer;
        background-color: initial;
        color:  initial;
        text-decoration: none;
    }
    
    .popover{
        max-width: 500px;
    }

    .custom-header {
        color: white; /* Set text color to white */
    }

    .custom-header .btn-block {
        color: white; /* Set button text color to white */
        font-size: 1em;
    }
</style>